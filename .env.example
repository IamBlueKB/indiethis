# ─── IndieThis — Environment Variables Reference ──────────────────────────────
# Copy to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Transaction pooler (port 6543) — used at runtime by Next.js
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1
# Direct connection (port 5432) — used by prisma db push/migrate only
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3456
AUTH_SECRET=your_auth_secret_here

# ─── Platform Admin ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@indiethis.com
ADMIN_PASSWORD=changeme123!
ADMIN_SECRET=your_admin_secret_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3456

# ─── Anthropic (admin AI features, page generation) ──────────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (Whisper — audio transcription) ───────────────────────────────────
# Required for: lyrics transcription from audio uploads
# Get your key from: https://platform.openai.com/api-keys
# Missing key → returns: "OPENAI_API_KEY is not configured"
OPENAI_API_KEY=your_openai_api_key_here

# ─── Replicate (cover art image generation) ───────────────────────────────────
# Required for: AI cover art generation (SDXL / Flux models)
# Get your token from: https://replicate.com/account/api-tokens
# Missing key → returns: "REPLICATE_API_TOKEN is not configured"
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ─── fal.ai (Kling 3.0 — primary AI video provider) ──────────────────────────
# Required for: AI music video generation (image-to-video, up to 3 min @ 4K 60fps)
# Get your key from: https://fal.ai/dashboard/keys
# Missing key → returns: "FAL_KEY is not configured"
# Cost: $0.029 per second of generated video
FAL_KEY=your_fal_ai_key_here

# ─── Runway (AI video fallback) ───────────────────────────────────────────────
# Optional fallback if fal.ai/Kling is unavailable
# Get your key from: https://app.runwayml.com/settings
# Missing key → skips Runway fallback silently
RUNWAY_API_KEY=your_runway_api_key_here

# ─── Dolby.io (mastering + audio analysis) ────────────────────────────────────
# Required for: AI mastering, BPM/key detection, audio enhancement
# Get your App Key and Secret from: https://dashboard.dolby.io
# Missing key → returns: "DOLBY_API_KEY is not configured"
DOLBY_API_KEY=your_dolby_api_key_here
DOLBY_API_SECRET=your_dolby_api_secret_here

# ─── Remotion Lambda (lyric video rendering) ──────────────────────────────────
# Required for: rendering lyric videos via AWS Lambda
# Deploy your Remotion bundle: https://www.remotion.dev/docs/lambda
# Missing key → returns: "REMOTION_SERVE_URL is not configured"
REMOTION_SERVE_URL=https://your-remotion-bundle.s3.amazonaws.com/bundle.json
# Lambda function name — deploy with: npx remotion lambda functions deploy
REMOTION_FUNCTION_NAME=remotion-render-4-0-436-mem2048mb-disk2048mb-120sec

# ─── AWS (required for Remotion Lambda) ───────────────────────────────────────
# IAM user needs: AWSLambdaRole, AmazonS3FullAccess on your renders bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# ─── UploadThing (file uploads) ───────────────────────────────────────────────
# Get your token from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your_uploadthing_token_here

# ─── Brevo (email + SMS) ──────────────────────────────────────────────────────
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=hello@indiethis.com
BREVO_FROM_NAME=IndieThis
BREVO_SMS_SENDER=IndieThis
BREVO_WAITLIST_LIST_ID=1
BREVO_ARTISTS_LIST_ID=2
BREVO_STUDIOS_LIST_ID=3
BREVO_NEWSLETTER_LIST_ID=4

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
