  status      String    @default("PENDING") // PENDING, APPROVED, REMOVED
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([status])
  @@index([contentType, contentId])
}

model FanFunding {
  id              String   @id @default(cuid())
