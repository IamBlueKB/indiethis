  artist          User     @relation("FanFundingReceived", fields: [artistId], references: [id])
  fanName         String?
  fanEmail        String
  amount          Int      // cents — what the fan paid
  creditsAwarded  Int      // credits added to artist platformCredits (amount/100, 1:1)
  stripePaymentId String?
  message         String?
  createdAt       DateTime @default(now())

