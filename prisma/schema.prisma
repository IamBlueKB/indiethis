// IndieThis — Prisma Schema
// Database: PostgreSQL
// Auth: NextAuth v5 (Credentials + JWT strategy)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")    // pooler URL (port 6543) — used at runtime
  directUrl = env("DIRECT_URL")      // direct URL (port 5432) — used by prisma db push/migrate
}

