// ─── Digital Sales ────────────────────────────────────────────────────────────

model DigitalProduct {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  type          DigitalProductType
  title         String
  price         Int
  description   String?
  coverArtUrl   String?
  genre         String?
  releaseYear   Int?
  copyright     String?
  explicit      Boolean             @default(false)
  songwriter    String?
  producer      String?
  isrc          String?
  tracks              Track[]             @relation("DigitalProductTracks")
  published           Boolean             @default(false)
  // Sample Pack fields
  samplePackFileUrl   String?
  samplePackFileSize  Int?                // bytes
  sampleCount         Int?                // number of audio files in zip
  previewSampleUrls   Json?               // String[] — up to 5 preview audio URLs
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  purchases           DigitalPurchase[]

  @@index([userId])
}

model DigitalPurchase {
  id               String         @id @default(cuid())
  digitalProductId String
  digitalProduct   DigitalProduct @relation(fields: [digitalProductId], references: [id])
  buyerId          String?
  buyerEmail       String
  amount           Int
  platformFee      Int
  artistEarnings   Int
  djAttributionId  String?
  djAttribution    DJAttribution?  @relation(fields: [djAttributionId], references: [id])
  stripePaymentId  String?
  downloadToken    String         @unique @default(cuid())
  downloadCount    Int            @default(0)
  maxDownloads     Int            @default(5)
  createdAt        DateTime       @default(now())

  @@index([digitalProductId])
  @@index([downloadToken])
}

enum DigitalProductType {
  SINGLE
  EP
  ALBUM
  SAMPLE_PACK
}

// ─── DJ Feature ───────────────────────────────────────────────────────────────

model DJProfile {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id])
  slug            String          @unique
  bio             String?
  genres          String[]
  city            String?
  profilePhotoUrl String?
  socialLinks     Json?
  isVerified      Boolean         @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?
  balance         Int             @default(0)
  totalEarnings   Int             @default(0)
  verificationStatus   String   @default("NONE") // NONE, PENDING, APPROVED, DENIED
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  crates               Crate[]
  sets                 DJSet[]
  events               DJEvent[]
  bookingInquiries     DJBookingInquiry[]
  attributions         DJAttribution[]
  withdrawals          DJWithdrawal[]
  collaboratingCrates  CrateCollaborator[]
  mixes                DJMix[]
  verificationApplication DJVerificationApplication?
}

model Crate {
  id            String              @id @default(cuid())
  djProfileId   String
  djProfile     DJProfile           @relation(fields: [djProfileId], references: [id])
  name          String
  description   String?
  isPublic      Boolean             @default(true)
  coverArtUrl   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  items         CrateItem[]
  collaborators CrateCollaborator[]
  invites       CrateInvite[]

  @@index([djProfileId])
}

model CrateItem {
  id        String   @id @default(cuid())
  crateId   String
  crate     Crate    @relation(fields: [crateId], references: [id])
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id])
  addedAt   DateTime @default(now())
  notes     String?

  @@unique([crateId, trackId])
  @@index([crateId])
}

model CrateCollaborator {
  id          String    @id @default(cuid())
  crateId     String
  crate       Crate     @relation(fields: [crateId], references: [id])
  djProfileId String
  djProfile   DJProfile @relation(fields: [djProfileId], references: [id])
  addedAt     DateTime  @default(now())

  @@unique([crateId, djProfileId])
}

model CrateInvite {
  id          String   @id @default(cuid())
  crateId     String
  crate       Crate    @relation(fields: [crateId], references: [id])
  invitedById String
  invitedId   String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  @@unique([crateId, invitedId])
  @@index([invitedId])
}

model DJSet {
  id           String    @id @default(cuid())
  djProfileId  String
  djProfile    DJProfile @relation(fields: [djProfileId], references: [id])
  title        String
  videoUrl     String
  thumbnailUrl String?
  duration     Int?
  venue        String?
  date         DateTime?
  createdAt    DateTime  @default(now())

  @@index([djProfileId])
}

model DJEvent {
  id          String    @id @default(cuid())
  djProfileId String
  djProfile   DJProfile @relation(fields: [djProfileId], references: [id])
  name        String
  venue       String
  city        String
  date        DateTime
  time        String?
  ticketUrl   String?
  description String?
  createdAt   DateTime  @default(now())

  @@index([djProfileId])
}

model DJBookingInquiry {
  id          String    @id @default(cuid())
  djProfileId String
  djProfile   DJProfile @relation(fields: [djProfileId], references: [id])
  name        String
  email       String
  phone       String?
  eventDate   DateTime?
  venue       String?
  message     String
  status      String    @default("PENDING")
  leadScore   Int?
  createdAt   DateTime  @default(now())

  @@index([djProfileId])
}

model DJAttribution {
  id              String          @id @default(cuid())
  djProfileId     String
  djProfile       DJProfile       @relation(fields: [djProfileId], references: [id])
  fanSessionId    String
  sourceType      String          // CRATE, MIX, PROFILE
  sourceId        String
  artistId        String
  amount          Int             @default(0)
  createdAt       DateTime        @default(now())
  expiresAt       DateTime
  purchases       DigitalPurchase[]

  @@index([djProfileId])
  @@index([fanSessionId])
}

model DJWithdrawal {
  id               String    @id @default(cuid())
  djProfileId      String
  djProfile        DJProfile @relation(fields: [djProfileId], references: [id])
  amount           Int
  stripePayoutId   String?
  stripeTransferId String?
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([djProfileId])
  @@index([stripeTransferId])
}

model DJMix {
  id          String       @id @default(cuid())
  djProfileId String
  djProfile   DJProfile    @relation(fields: [djProfileId], references: [id])
  title       String
  audioUrl    String
  coverArtUrl String?
  duration    Int?
  description String?
  tracklist      DJMixTrack[]
  canvasVideoUrl String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([djProfileId])
}

model DJMixTrack {
  id        String   @id @default(cuid())
  djMixId   String
  djMix     DJMix    @relation(fields: [djMixId], references: [id], onDelete: Cascade)
  trackId   String?
  track     Track?   @relation(fields: [trackId], references: [id])
  position  Int
  startTime Int?
  title     String?
  artist    String?

  @@index([djMixId])
}

model DJVerificationApplication {
  id          String    @id @default(cuid())
  djProfileId String    @unique
  djProfile   DJProfile @relation(fields: [djProfileId], references: [id])
  status      String    @default("PENDING") // PENDING, APPROVED, DENIED
  adminNote   String?
  appliedAt   DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  @@index([status])
}

