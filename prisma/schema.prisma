  @@unique([artistId, email])
  @@index([artistId])
}

// ─── Artist Support (Pay-What-You-Want Tips) ──────────────────────────────────

model ArtistSupport {
  id               String   @id @default(cuid())
  artistId         String
  supporterEmail   String
  amount           Float                    // in dollars
  message          String?
  stripePaymentId  String?
  createdAt        DateTime @default(now())

  artist           User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([artistId, supporterEmail])
}

// ─── Fan Contacts (artist page email/SMS capture) ─────────────────────────────

model FanContact {
  id        String          @id @default(cuid())
  artistId  String
  email     String
  phone     String?
  zip       String?
  source    FanContactSource
  createdAt DateTime        @default(now())

  artist    User            @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, email, source])
  @@index([artistId])
  @@index([artistId, source])
}

// ─── Fan Score (cached spend ranking per artist) ─────────────────────────────
// Recomputed on every MERCH and SUPPORT_TIP webhook event.
// Also rebuilt on demand via POST /api/dashboard/fan-scores/refresh.

model FanScore {
  id          String    @id @default(cuid())
  artistId    String
  email       String
  totalSpend  Float     @default(0)
  merchSpend  Float     @default(0)
  tipSpend    Float     @default(0)
  orderCount  Int       @default(0)
  tipCount    Int       @default(0)
  lastSpentAt DateTime?
  updatedAt   DateTime  @updatedAt

  artist      User      @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, email])
  @@index([artistId])
  @@index([artistId, totalSpend])
}

// ─── SMS Broadcast Log ────────────────────────────────────────────────────────

model BroadcastLog {
  id             String   @id @default(cuid())
  artistId       String
  message        String   @db.Text
  segment        String   // e.g. "ALL" | "RELEASE_NOTIFY" | "SHOW_NOTIFY" | "TOP_SPENDERS" | "MERCH_BUYERS" | "ZIP:90210"
  recipientCount Int
  successCount   Int      @default(0)
  sentAt         DateTime @default(now())

  artist         User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([artistId, sentAt])
}

// ─── Artist Booking Inquiries (public contact form) ──────────────────────────

model ArtistBookingInquiry {
  id          String   @id @default(cuid())
  artistId    String
  name        String
  email       String
  inquiryType String   // "Booking" | "Feature" | "Press" | "Management" | "Other"
  message     String
  createdAt   DateTime @default(now())

  artist      User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
}

// ─── Admin Accounts ───────────────────────────────────────────────────────────

model AdminAccount {
