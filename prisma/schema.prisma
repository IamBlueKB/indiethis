  artistId    String
  title       String
  coverUrl    String?
  releaseDate DateTime?
  type        ReleaseType @default(SINGLE)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())

  artist       User        @relation(fields: [artistId], references: [id], onDelete: Cascade)
