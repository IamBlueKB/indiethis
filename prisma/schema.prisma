  @@index([artistId])
}

model ArtistPhoto {
  id        String   @id @default(cuid())
  artistId  String
  imageUrl  String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  artist    User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
}

model ArtistTestimonial {
  id          String   @id @default(cuid())
  artistId    String
  quote       String
  attribution String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

