  agentType  AgentType
  action     String
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime  @default(now())

  @@index([agentType])
  @@index([createdAt])
  @@index([targetId])
}

enum AgentType {
  CHURN_PREVENTION
  REVENUE_OPTIMIZATION
  RELEASE_STRATEGY
  FAN_ENGAGEMENT
  SESSION_FOLLOWUP
  AR_INTELLIGENCE
  CONTENT_MODERATION
  LEAD_SCORING
  CREATIVE_PROMPT
  INACTIVE_CONTENT
  PAYMENT_RECOVERY
  TREND_FORECASTER
  PRODUCER_ARTIST_MATCH
  BOOKING_AGENT
  COLLABORATION_MATCHMAKER
  RELEASE_BUNDLE
  REVENUE_REPORT
  VIDEO_CONVERSION
  COVER_ART_CONVERSION
  LYRIC_VIDEO_CONVERSION
  MASTERING_CONVERSION
  MIX_QUALITY_FOLLOWUP
  ALBUM_MASTERING_NUDGE
