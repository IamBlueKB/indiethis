generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                       String                 @id @default(cuid())
  email                    String                 @unique
  emailVerified            DateTime?
  phone                    String?
  passwordHash             String?
  authProvider             String                 @default("email")
  role                     Role                   @default(ARTIST)
  name                     String
  artistName               String?
  bio                      String?
  photo                    String?
  instagramHandle          String?
  tiktokHandle             String?
  youtubeChannel           String?
  spotifyUrl               String?
  appleMusicUrl            String?
  stripeCustomerId         String?
  stripeConnectId          String?
  passwordResetToken       String?                @unique
  passwordResetExpiry      DateTime?
  igFollowClaimed          Boolean                @default(false)
  referralCode             String?                @unique
  referredById             String?
  referredByCode           String?
  referralRewardTier       ReferralRewardTier     @default(NONE)
  artistSlug               String?                @unique
  isComped                 Boolean                @default(false)
  compExpiresAt            DateTime?
  isSuspended              Boolean                @default(false)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  lastLoginAt              DateTime?
  city                     String?
  genres                   String[]
  soundcloudUrl            String?
  signupPath               String?
  onboardingStep           Int                    @default(0)
  planSelectedAt           DateTime?
  setupCompletedAt         DateTime?
  firstVisitAt             DateTime?
  firstContentAt           DateTime?
  pagePublishedAt          DateTime?
  autoSigninToken          String?                @unique
  autoSigninTokenExpiresAt DateTime?
  smsOptIn                 Boolean                @default(false)
  djMode                   Boolean                @default(false)
  djDiscoveryOptIn         Boolean                @default(false)
  churnRiskScore           Int                    @default(0)
  artistBalance            Float                  @default(0)
  artistTotalEarnings      Float                  @default(0)
  platformCredits          Int                    @default(0)
  supporterCount           Int                    @default(0)
  winBackUsed              Boolean                @default(false)
  openToCollaborations     Boolean                @default(false)
  aiGenerations            AIGeneration[]
  artistWithdrawals        ArtistWithdrawal[]
  accounts                 Account[]
  affiliate                Affiliate?
  digitalProducts          DigitalProduct[]
  djProfile                DJProfile?
  affiliateReferral        AffiliateReferral?     @relation("AffiliateReferredUser")
  ambassador               Ambassador?
  artistBookingInquiries   ArtistBookingInquiry[]
  artistCollaborators      ArtistCollaborator[]
  artistPhotos             ArtistPhoto[]
  artistPressItems         ArtistPressItem[]
  artistReleases           ArtistRelease[]
  artistShows              ArtistShow[]
  artistSite               ArtistSite?
  artistSupports           ArtistSupport[]
  artistTestimonials       ArtistTestimonial[]
  artistVideos             ArtistVideo[]
  artistLicenses           BeatLicense[]          @relation("ArtistLicenses")
  producerLicenses         BeatLicense[]          @relation("ProducerLicenses")
  receivedPreviews         BeatPreview[]          @relation("ArtistPreviews")
  producedPreviews         BeatPreview[]          @relation("ProducerPreviews")
  sessions                 BookingSession[]
  broadcastLogs            BroadcastLog[]
  deliveredFiles           DeliveredFile[]
  featuredCards            ExploreFeatureCard[]   @relation("FeaturedArtist")
  fanAutomations           FanAutomation[]
  fanContacts              FanContact[]
  fanScores                FanScore[]
  licenseDocuments         LicenseDocument[]
  artistLinkClicks         LinkClick[]            @relation("ArtistLinkClicks")
  merchProducts            MerchProduct[]
  notifications            Notification[]
  onboardingEmails         OnboardingEmailLog[]
  artistPageViews          PageView[]             @relation("ArtistPageViews")
  payments                 Payment[]
  preSaveCampaigns         PreSaveCampaign[]
  producerLeaseSettings    ProducerLeaseSettings?
  producerProfile          ProducerProfile?
  promoRedemptions         PromoRedemption[]
  reEngagementEmails       ReEngagementEmailLog[]
  receipts                 Receipt[]
  recentPlays              RecentPlay[]
  referralReceived         Referral?              @relation("ReferredReferrals")
  referralsGiven           Referral[]             @relation("ReferrerReferrals")
  releasePlans             ReleasePlan[]
  sampleLogs               SampleLog[]
  artistSessionNotes       SessionNote[]
  showInterests            ShowInterest[]
  splits                   Split[]                @relation("UserSplits")
  splitSheetsCreated       SplitSheet[]           @relation("SplitSheetCreator")
  stemSeparations          StemSeparation[]
  trackShieldScans         TrackShieldScan[]
  artistStreamLeases       StreamLease[]          @relation("ArtistStreamLeases")
  producerStreamLeases     StreamLease[]          @relation("ProducerStreamLeases")
  streamLeaseBookmarks     StreamLeaseBookmark[]
  ownedStudios             Studio[]
  studios                  StudioArtist[]
  subscription             Subscription?
  tracks                   Track[]
  artistTrackPlays         TrackPlay[]            @relation("ArtistTrackPlays")
  referredBy               User?                  @relation("Referrals", fields: [referredById], references: [id])
  referrals                User[]                 @relation("Referrals")
  attribution              UserAttribution?
  youtubeSync              YouTubeSync?
  youtubeReferences        YoutubeReference[]
  moderationFlags          ModerationFlag[]
  fanFundingReceived       FanFunding[]           @relation("FanFundingReceived")
}

model Studio {
  id                       String                 @id @default(cuid())
  name                     String
  slug                     String                 @unique
  address                  String?
  phone                    String?
  email                    String?
  description              String?
  hours                    String?
  streetAddress            String?
  city                     String?
  state                    String?
  zipCode                  String?
  instagram                String?
  tiktok                   String?
  youtube                  String?
  facebook                 String?
  cashAppHandle            String?
  zelleHandle              String?
  paypalHandle             String?
  venmoHandle              String?
  stripePaymentsEnabled    Boolean                @default(false)
  photos                   String[]
  logo                     String?
  heroImage                String?
  tagline                  String?
  services                 String[]
  servicesJson             String?
  testimonials             String?
  twitter                  String?
  isEnterprise             Boolean                @default(false)
  studioTier               StudioTier             @default(PRO)
  template                 StudioTemplate         @default(CLASSIC)
  accentColor              String?
  customDomain             String?
  isPublished              Boolean                @default(false)
  bio                      String?
  logoUrl                  String?
  galleryImages            Json?
  studioHours              Json?
  hoursNote                String?
  socialLinks              Json?
  paymentMethods           Json?
  featuredArtists          Json?
  pageConfig               Json?
  tierOverride             String?
  moderationStatus         ModerationStatus       @default(CLEAN)
  moderationReason         String?
  moderationScannedAt      DateTime?
  onboardingCompleted      Boolean                @default(false)
  generationsUsedThisMonth Int                    @default(0)
  generationResetDate      DateTime?
  referralCredits          Float                  @default(0)
  referralCreditHistory    Json?
  emailSequenceEnabled     Boolean                @default(false)
  followUpEmailsEnabled    Boolean                @default(true)
  averageSessionRate       Float                  @default(150)
  ownerId                  String
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  activityLog              ActivityLog[]
  sessions                 BookingSession[]
  contacts                 Contact[]
  contactSubmissions       ContactSubmission[]
  deliveredFiles           DeliveredFile[]
  emailCampaigns           EmailCampaign[]
  generationLogs           GenerationLog[]
  intakeLinks              IntakeLink[]
  intakeSubmissions        IntakeSubmission[]
  invoices                 Invoice[]
  pageViews                PageView[]
  quickSends               QuickSend[]
  scheduledEmails          ScheduledEmail[]
  sessionNotes             SessionNote[]
  owner                    User                   @relation(fields: [ownerId], references: [id])
  artists                  StudioArtist[]
  credits                  StudioCredit[]
  engineers                StudioEngineer[]
  equipment                StudioEquipment[]
  portfolioTracks          StudioPortfolioTrack[]
}

model StudioArtist {
  id       String   @id @default(cuid())
  studioId String
  artistId String
  joinedAt DateTime @default(now())
  artist   User     @relation(fields: [artistId], references: [id])
  studio   Studio   @relation(fields: [studioId], references: [id])

  @@unique([studioId, artistId])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  tier                   SubscriptionTier
  status                 SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId   String?
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  aiVideoCreditsUsed     Int                @default(0)
  aiVideoCreditsLimit    Int
  aiArtCreditsUsed       Int                @default(0)
  aiArtCreditsLimit      Int
  aiMasterCreditsUsed    Int                @default(0)
  aiMasterCreditsLimit   Int
  lyricVideoCreditsUsed  Int                @default(0)
  lyricVideoCreditsLimit Int
  aarReportCreditsUsed   Int                @default(0)
  aarReportCreditsLimit  Int
  pressKitCreditsUsed    Int                @default(0)
  pressKitCreditsLimit   Int                @default(0)
  smsBroadcastsUsed      Int                @default(0)
  cancelReason           String?
  canceledAt             DateTime?
  streamLeaseGraceUntil  DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id])
}

model BookingSession {
  id             String          @id @default(cuid())
  studioId       String
  artistId       String?
  contactId      String?
  dateTime       DateTime
  duration       Int?
  sessionType    String?
  status         SessionStatus   @default(PENDING)
  paymentStatus  PaymentStatus   @default(UNPAID)
  paymentMethod  PaymentMethod?
  intakeData     Json?
  notes          String?
  engineerNotes  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  artist         User?           @relation(fields: [artistId], references: [id])
  contact        Contact?        @relation(fields: [contactId], references: [id])
  studio         Studio          @relation(fields: [studioId], references: [id])
  deliveredFiles DeliveredFile[]
  sessionNotes   SessionNote[]
}

model Track {
  id                   String                @id @default(cuid())
  artistId             String
  title                String
  description          String?
  fileUrl              String
  coverArtUrl          String?
  price                Float?
  status               TrackStatus           @default(DRAFT)
  plays                Int                   @default(0)
  downloads            Int                   @default(0)
  earnings             Float                 @default(0)
  projectName          String?
  releaseId            String?
  bpm                  Int?
  musicalKey           String?
  audioHash            String?
  totalLicenses        Int                   @default(0)
  totalStreamLeases    Int                   @default(0)
  totalPlays           Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  genre                String?
  isrc                 String?
  videoBeatLinks       ArtistVideo[]         @relation("VideoBeatLink")
  videoTrackLinks      ArtistVideo[]         @relation("VideoTrackLink")
  audioFeatures        AudioFeatures?
  beatLeaseSettings    BeatLeaseSettings?
  beatLicenses         BeatLicense[]
  beatPreviews         BeatPreview[]
  licenseDocuments     LicenseDocument[]
  recentPlays          RecentPlay[]
  releasePlans         ReleasePlan[]
  sampleLogs           SampleLog[]
  splitSheet           SplitSheet?
  streamLeases         StreamLease[]
  streamLeaseBookmarks StreamLeaseBookmark[]
  artist               User                  @relation(fields: [artistId], references: [id])
  release              ArtistRelease?        @relation(fields: [releaseId], references: [id])
  trackPlays           TrackPlay[]
  digitalProducts      DigitalProduct[]      @relation("DigitalProductTracks")
  crateItems           CrateItem[]
  djMixTracks          DJMixTrack[]
  fingerprint          AudioFingerprint?
  shieldResults        TrackShieldResult[]
  canvasVideoUrl       String?
  producer             String?
  songwriter           String?
  featuredArtists      String?
  qualityScore         Int       @default(0)
  lyrics               String?
}

model AudioFingerprint {
  id          String   @id @default(cuid())
  trackId     String   @unique
  track       Track    @relation(fields: [trackId], references: [id])
  fingerprint String
  duration    Int
  createdAt   DateTime @default(now())
}

model DeliveredFile {
  id               String          @id @default(cuid())
  sessionId        String?
  artistId         String
  studioId         String
  contactId        String?
  fileUrl          String
  fileName         String
  notes            String?
  notificationSent Boolean         @default(false)
  deliveredAt      DateTime        @default(now())
  artist           User            @relation(fields: [artistId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])
  session          BookingSession? @relation(fields: [sessionId], references: [id])
  studio           Studio          @relation(fields: [studioId], references: [id])
}

model MerchProduct {
  id                String          @id @default(cuid())
  artistId          String
  fulfillmentType   FulfillmentType @default(POD)
  printfulProductId Int?            // Printful catalog product ID (null for self-fulfilled)
  title             String
  description       String?
  imageUrl          String          // primary/hero image URL
  imageUrls         String[]        @default([]) // gallery (self-fulfilled products)
  markup            Float           @default(0)  // $ artist markup per item (POD only)
  shippingCost      Float           @default(5.99) // flat-rate shipping for self-fulfilled
  returnPolicy      String?         // required for self-fulfilled
  processingDays    Int             @default(3)  // estimated fulfillment days (self-fulfilled)
  isActive          Boolean         @default(true)
  isFeatured        Boolean         @default(false) // pinned to explore by PLATFORM_ADMIN
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  artist            User            @relation(fields: [artistId], references: [id])
  variants          MerchVariant[]
  orderItems        MerchOrderItem[]
  videoMerchLinks   ArtistVideo[]   @relation("VideoMerchLink")
}

model MerchVariant {
  id                String         @id @default(cuid())
  productId         String
  printfulVariantId Int?           // Printful catalog variant ID (null for self-fulfilled)
  size              String
  color             String
  colorCode         String
  imageUrl          String?
  basePrice         Float          // Printful base cost (0 for self-fulfilled)
  retailPrice       Float          // artist-set sale price
  inStock           Boolean        @default(true)
  stockQuantity     Int?           // null = unlimited (self-fulfilled only)
  createdAt         DateTime       @default(now())
  product           MerchProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems        MerchOrderItem[]
}

model MerchOrder {
  id                String            @id @default(cuid())
  artistId          String
  buyerEmail        String
  buyerName         String?
  shippingAddress   Json?
  stripePaymentId   String?
  printfulOrderId   Int?
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  trackingNumber    String?
  trackingUrl       String?
  totalPrice        Float
  shippingCost      Float           @default(0)
  platformCut       Float
  artistEarnings    Float
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
  items             MerchOrderItem[]
}

model MerchOrderItem {
  id        String       @id @default(cuid())
  orderId   String
  variantId String
  productId String
  quantity  Int
  unitPrice Float
  subtotal  Float
  order     MerchOrder   @relation(fields: [orderId],   references: [id])
  variant   MerchVariant @relation(fields: [variantId], references: [id])
  product   MerchProduct @relation(fields: [productId], references: [id])
}

model ArtistWithdrawal {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  amount           Float
  stripeTransferId String?
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
}

model AIGeneration {
  id         String             @id @default(cuid())
  artistId   String
  type       AIGenerationType
  inputData  Json?
  outputData Json?
  outputUrl  String?
  creditUsed Boolean            @default(false)
  paymentId  String?
  status     AIGenerationStatus @default(QUEUED)
  createdAt  DateTime           @default(now())
  artist     User               @relation(fields: [artistId], references: [id])
}

model ArtistSite {
  id                    String             @id @default(cuid())
  artistId              String             @unique
  template              ArtistSiteTemplate @default(TEMPLATE_1)
  colorScheme           Json?
  heroImage             String?
  bioContent            String?
  showMusic             Boolean            @default(true)
  showVideos            Boolean            @default(true)
  showMerch             Boolean            @default(true)
  showContact           Boolean            @default(false)
  followGateEnabled     Boolean            @default(false)
  pwywEnabled           Boolean            @default(false)
  credentials           String[]
  bookingRate           Float?
  customDomain          String?
  isPublished           Boolean            @default(false)
  draftMode             Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  pinnedMessage         String?
  pinnedActionText      String?
  pinnedActionUrl       String?
  activityTickerEnabled Boolean            @default(false)
  genre                 String?
  role                  String?
  city                  String?
  soundcloudUrl         String?
  artist                User               @relation(fields: [artistId], references: [id])
}

model YoutubeReference {
  id           String   @id @default(cuid())
  artistId     String
  url          String
  videoId      String
  title        String
  thumbnailUrl String
  authorName   String?
  projectTag   String?
  folder       String?
  createdAt    DateTime @default(now())
  artist       User     @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  type            String
  amount          Float
  method          String?
  status          String
  stripePaymentId String?
  metadata        Json?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model EmailCampaign {
  id              String    @id @default(cuid())
  studioId        String
  subject         String
  body            String
  recipientFilter Json?
  recipientCount  Int       @default(0)
  openCount       Int       @default(0)
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  attachmentUrls  String[]
  studio          Studio    @relation(fields: [studioId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id                  String             @id @default(cuid())
  studioId            String
  name                String
  firstName           String?
  lastName            String?
  email               String?
  phone               String?
  photoUrl            String?
  instagramHandle     String?
  genre               String?
  notes               String?
  source              ContactSource      @default(MANUAL)
  tags                String[]           @default([])
  totalSpent          Float              @default(0)
  lastSessionDate     DateTime?
  referredToIndieThis Boolean            @default(false)
  convertedToBooking  Boolean            @default(false)
  convertedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  activityLog         ActivityLog[]
  sessions            BookingSession[]
  studio              Studio             @relation(fields: [studioId], references: [id])
  deliveredFiles      DeliveredFile[]
  intakeSubmissions   IntakeSubmission[]
  invoices            Invoice[]
}

model ActivityLog {
  id          String          @id @default(cuid())
  contactId   String
  studioId    String
  type        ActivityLogType
  description String
  metadata    Json?
  createdAt   DateTime        @default(now())
  contact     Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  studio      Studio          @relation(fields: [studioId], references: [id])
}

model IntakeLink {
  id           String            @id @default(cuid())
  studioId     String
  contactId    String?
  token        String            @unique
  name         String?
  email        String?
  phone        String?
  sessionDate  DateTime?
  sessionTime  String?
  endTime      String?
  hourlyRate   Float?
  sessionHours Float?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime          @default(now())
  studio       Studio            @relation(fields: [studioId], references: [id])
  submission   IntakeSubmission?
}

model IntakeSubmission {
  id                   String     @id @default(cuid())
  intakeLinkId         String     @unique
  studioId             String
  contactId            String?
  artistName           String
  genre                String?
  projectDesc          String?
  youtubeLinks         String[]
  fileUrls             String[]
  photoUrl             String?
  notes                String?
  bpmDetected          Int?
  keyDetected          String?
  instagram            String?
  tiktok               String?
  youtubeHandle        String?
  paymentMethod        String?
  depositPaid          Boolean    @default(false)
  depositAmount        Float?
  aiVideoRequested     Boolean    @default(false)
  convertedToBookingId String?
  status               String     @default("PENDING")
  leadScore            Int?
  createdAt            DateTime   @default(now())
  contact              Contact?   @relation(fields: [contactId], references: [id])
  intakeLink           IntakeLink @relation(fields: [intakeLinkId], references: [id])
  studio               Studio     @relation(fields: [studioId], references: [id])
}

model QuickSend {
  id                   String    @id @default(cuid())
  studioId             String
  contactId            String?
  senderName           String
  recipientEmail       String
  recipientPhone       String?
  fileUrls             String[]
  message              String?
  token                String    @unique
  expiresAt            DateTime
  downloadedAt         DateTime?
  sendFollowUpSequence Boolean   @default(false)
  createdAt            DateTime  @default(now())
  studio               Studio    @relation(fields: [studioId], references: [id])
}

model BeatPreview {
  id             String            @id @default(cuid())
  producerId     String
  artistId       String?
  trackId        String
  expiresAt      DateTime
  isDownloadable Boolean           @default(false)
  status         BeatPreviewStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  licenses       BeatLicense[]
  artist         User?             @relation("ArtistPreviews", fields: [artistId], references: [id])
  producer       User              @relation("ProducerPreviews", fields: [producerId], references: [id])
  track          Track             @relation(fields: [trackId], references: [id])
}

model BeatLicense {
  id            String      @id @default(cuid())
  beatPreviewId String
  trackId       String
  producerId    String
  artistId      String
  licenseType   LicenseType
  customTerms   String?
  price         Float
  status        String      @default("ACTIVE")
  pdfUrl        String?
  createdAt     DateTime    @default(now())
  artist        User        @relation("ArtistLicenses", fields: [artistId], references: [id])
  beatPreview   BeatPreview @relation(fields: [beatPreviewId], references: [id])
  producer      User        @relation("ProducerLicenses", fields: [producerId], references: [id])
  track         Track       @relation(fields: [trackId], references: [id])
}

model Receipt {
  id              String      @id @default(cuid())
  userId          String
  type            ReceiptType
  description     String
  amount          Float
  paymentMethod   String?
  stripePaymentId String?
  pdfUrl          String?
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String        @id @default(cuid())
  studioId      String
  contactId     String
  invoiceNumber Int
  lineItems     Json
  subtotal      Float
  tax           Float         @default(0)
  taxRate       Float         @default(0)
  total         Float
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  paymentMethod String?
  paidAt        DateTime?
  remindersSent Int           @default(0)
  notes         String?
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contact       Contact       @relation(fields: [contactId], references: [id])
  studio        Studio        @relation(fields: [studioId], references: [id])

  @@unique([studioId, invoiceNumber])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  email     String
  phone     String?
  message   String
  source    String   @default("PUBLIC_PAGE")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

model GenerationLog {
  id             String         @id @default(cuid())
  studioId       String
  template       StudioTemplate
  configSnapshot Json
  createdAt      DateTime       @default(now())
  wasPaid        Boolean        @default(false)
  studio         Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

model PageView {
  id       String   @id @default(cuid())
  studioId String?
  artistId String?
  viewedAt DateTime @default(now())
  ipHash   String
  referrer String?
