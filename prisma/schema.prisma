  @@index([createdAt])
}

model PromoPopup {
  id              String    @id @default(cuid())
  title           String
  subtitle        String?
  ctaText         String?
  ctaUrl          String?
  imageUrl        String?
  backgroundColor String?
  pages           Json
  priority        Int       @default(0)
  frequency       String    @default("ONCE_PER_SESSION")
  trigger         String    @default("ON_LOAD")
  triggerDelay    Int?
  active          Boolean   @default(false)
  startDate       DateTime?
  endDate         DateTime?
  impressions     Int       @default(0)
  dismissals      Int       @default(0)
  ctaClicks       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Revenue Report ───────────────────────────────────────────────────────────

model RevenueReportConfig {
  id              String   @id @default(cuid())
  frequency       String   @default("WEEKLY") // DAILY, WEEKLY, MONTHLY
  dayOfWeek       Int      @default(1) // 0=Sunday, 1=Monday (for WEEKLY)
  dayOfMonth      Int      @default(1) // 1-28 (for MONTHLY)
  timeUtc         String   @default("12:00") // 24hr UTC time HH:00
  recipients      Json     @default("[]")
  enabledSections Json     @default("[\"revenue\",\"users\",\"products\",\"engagement\",\"agents\",\"goals\"]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RevenueReportAlert {
  id              String    @id @default(cuid())
  metric          String    // DAILY_REVENUE, DAILY_CHURN, DAILY_SIGNUPS
  condition       String    // BELOW, ABOVE
  threshold       Int       // cents for revenue, count for users
  active          Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
}

model RevenueReportGoal {
  id           String   @id @default(cuid())
  metric       String   // SUBSCRIBERS, MRR, REVENUE, SIGNUPS
  targetValue  Int      // cents for money, count for users
  currentValue Int      @default(0)
  period       String   // "2026-04" year-month format
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([period])
}

model RevenueReportLog {
  id        String   @id @default(cuid())
  period    String   // "2026-04-07", "2026-W15", or "2026-04"
  frequency String   // DAILY, WEEKLY, MONTHLY
  data      Json
  sentTo    Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── Music Video Studio ───────────────────────────────────────────────────────

model MusicVideo {
  id              String   @id @default(cuid())
  userId          String?  // null for non-subscribers / guests
  guestEmail      String?  // delivery email for non-subscribers
  trackId         String?  // linked IndieThis Track (subscribers only)
  trackTitle      String
  trackDuration   Int      // seconds
  audioUrl        String   // uploaded or pulled from Track.fileUrl

  mode            String   // QUICK | DIRECTOR
  videoLength     String   // SHORT | STANDARD | EXTENDED
  status          String   @default("PENDING")
  // PENDING → ANALYZING → PLANNING → GENERATING → STITCHING → COMPLETE | FAILED

  // Style & vision
  style           String?  // VideoStyle.name chosen by user
  visionPrompt    String?  // free-text description from user
  aspectRatio     String   @default("16:9") // 16:9 | 9:16 | 1:1

  // Director Mode
  creativeBrief   Json?    // Claude-generated brief object
  shotList        Json?    // Scene[]: { index, prompt, model, startTime, endTime, type, ... }
  characterRefs     Json?    // String[] of reference image URLs
  referenceImageUrl String?  // primary image URL for scene generation
  imageSource       String?  // UPLOAD | AVATAR | AI_GENERATED
  conversationLog Json?    // ChatMessage[]: { role, content, createdAt }

  // Song analysis (populated by song-analyzer)
  songStructure   Json?    // SongAnalysis object
  bpm             Int?
  musicalKey      String?
  energy          Float?
  lyrics          String?
  lyricTimestamps Json?    // { word, start, end }[]

  // Output
  scenes          Json?    // GeneratedScene[]: { sceneIndex, videoUrl, model, prompt, startTime, endTime, thumbnailUrl }
  finalVideoUrl   String?  // primary stitched output URL
  finalVideoUrls  Json?    // { "16:9": url, "9:16": url, "1:1": url }
  thumbnailUrl    String?

  // Billing
  stripePaymentId String?
  amount          Int      // cents — what the user paid (0 for included credits)

  // Director Mode regen flag (one free redo per video)
  sceneRegenUsed  Boolean  @default(false)

  // Video Conversion Agent — non-subscriber email sequence
  conversionStep      Int      @default(0)   // 0=no emails, 1=email1, 2=email2, 3=email3, 4=done
  conversionNextAt    DateTime?              // when to send the next conversion email
  conversionPromoCode String?               // Stripe promo code string for Email 4
  conversionDone      Boolean  @default(false)
  conversionAnyOpened Boolean  @default(false) // true once a link in any email was clicked
  abandonedCartSent   Boolean  @default(false)  // true once abandoned-cart recovery email sent

  // Quality gate (Claude Vision post-generation check)
  qaApproved      Boolean? // null = not checked; true = passed; false = low quality warning
  qaReport        String?  // JSON: { reason, recommendation, checkedAt }

  // Progress tracking
  progress        Int      @default(0)  // 0-100
  currentStep     String?  // human-readable step description
  errorMessage    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?          @relation(fields: [userId], references: [id])
  feedbacks       VideoFeedback[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Artist feedback on a generated music video (used for prompt learning)
model VideoFeedback {
  id           String     @id @default(cuid())
  musicVideoId String
  sceneIndex   Int        @default(-1)  // -1 = overall video; >=0 = specific scene index
  rating       Int?       // 1–5 star rating
  liked        Boolean?   // thumbs up (true) / thumbs down (false)
  notes        String?    // optional artist comment
  promptUsed   String?    // the generation prompt for this scene
  modelUsed    String?    // the fal.ai model ID used
  createdAt    DateTime   @default(now())

  musicVideo   MusicVideo @relation(fields: [musicVideoId], references: [id], onDelete: Cascade)

  @@index([musicVideoId])
  @@index([createdAt])
}

// Generic key-value config store — used by learning agents to persist insights
model SystemConfig {
  key       String   @id
  value     String   // JSON-encoded value
  updatedAt DateTime @updatedAt
}

// Lookup table: maps fal.ai request_id → MusicVideo scene
// Created when a scene is submitted via fal.queue.submit(); resolved when webhook fires.
model FalSceneJob {
  id           String   @id @default(cuid())
  requestId    String   @unique   // fal.ai request_id returned by fal.queue.submit()
  musicVideoId String
  sceneIndex   Int
  sceneTotal   Int                // total number of scenes expected for this video
  model        String?            // fal.ai model ID used for this submission
  status       String   @default("PENDING")  // PENDING | COMPLETE | FAILED
  videoUrl     String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([musicVideoId])
  @@index([status])
}

// Lookup table: maps fal.ai request_id → MusicVideo keyframe job
// Created by startKeyframeGeneration(); resolved when /webhook/keyframe fires.
model FalKeyframeJob {
  id           String   @id @default(cuid())
  requestId    String   @unique   // fal.ai request_id returned by fal.queue.submit()
  musicVideoId String
  sceneIndex   Int
  totalScenes  Int
  status       String   @default("PENDING")  // PENDING | COMPLETE | FAILED
  imageUrl     String?  // UploadThing permanent URL once complete
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([musicVideoId])
  @@index([status])
}

model VideoStyle {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // CINEMATIC | ANIMATED | ABSTRACT | RETRO | DARK | BRIGHT
  previewUrl  String   // short looping preview video URL
  promptBase  String   // prepended to every scene prompt for visual consistency
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  presets     VideoPreset[]

  @@index([category])
  @@index([sortOrder])
}

model VideoPreset {
  id             String   @id @default(cuid())
  name           String   @unique  // "Hip-Hop Performance"
  genre          String            // HIP_HOP | RNB | POP | EDM | ROCK | INDIE | LATIN | ACOUSTIC | ABSTRACT | NARRATIVE
  description    String            // one-line description shown on preset card
  previewUrl     String?           // 3-second looping preview video URL
  styleId        String?           // optional FK to VideoStyle
  styleName      String?           // VideoStyle.name — used to pre-select style in wizard
  moodArc        String            // intense_throughout | dark_to_bright | building_energy | emotional_journey
  cameraSequence Json              // { intro, verse, chorus, bridge, outro } → CameraDirectionKey
  briefTemplate  Json              // { logline, tone, colorPalette, visualThemes, cinematography }
  defaultFilmLook String  @default("clean_digital") // FilmLookKey — pre-set for all scenes when preset is applied
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  style          VideoStyle? @relation(fields: [styleId], references: [id])

  @@index([genre])
  @@index([sortOrder])
  @@index([active])
}

// ─── Cover Art Studio ─────────────────────────────────────────────────────────

model CoverArtStyle {
  id         String        @id @default(cuid())
  name       String        @unique
  category   String        // MINIMAL, DARK, VIBRANT, CLASSIC, EXPERIMENTAL
  previewUrl String        // example cover art image URL
  promptBase String        // base prompt blended with artist description by Claude
  sortOrder  Int           @default(0)
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  jobs       CoverArtJob[]
}

model CoverArtJob {
  id                  String         @id @default(cuid())
  // Owner — null for guests
  userId              String?        // FK to User.id — no explicit Prisma relation (avoids touching large User model)
  guestEmail          String?
  guestName           String?

  // Configuration
  tier                String         // STANDARD | PREMIUM | PRO
  stripePaymentId     String?        // set after successful Stripe checkout
  styleId             String?
  style               CoverArtStyle? @relation(fields: [styleId], references: [id])
  trackId             String?        // optional linked Track.id for "Set as Track Cover"

  // Prompt
  prompt              String         // artist's raw description
  enhancedPrompt      String?        // Claude-enhanced prompt used for generation

  // Reference image (Premium / Pro)
  referenceImageUrl   String?

  // Output — initial generation
  variationUrls       Json?          // String[] of generated image URLs (4 or 8)
  selectedUrl         String?        // URL the artist picked from initial variations

  // Pro tier refinement
  refinementRound     Int            @default(0)   // 0=initial, 1=round1 done, 2=round2 done
  refinementHistory   Json?          // RefinementRound[]: {round, instruction, prompt, urls, selectedUrl}[]

  // Job state
  status              String         @default("PENDING")
  // PENDING → GENERATING → COMPLETE | FAILED
  errorMessage        String?

  // Non-subscriber conversion tracking (mirrors MusicVideo pattern)
  conversionStep      Int            @default(0)
  conversionNextAt    DateTime?
  conversionPromoCode String?
  conversionAnyOpened Boolean        @default(false)
  conversionDone      Boolean        @default(false)
  abandonedCartSent   Boolean        @default(false)

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([userId])
  @@index([guestEmail])
  @@index([status])
  @@index([createdAt])
}

// ─── Lyric Video Studio ───────────────────────────────────────────────────────

model TypographyStyle {
  id            String       @id @default(cuid())
  name          String       @unique  // KARAOKE | KINETIC_BOUNCE | SMOOTH_FADE | GLITCH | HANDWRITTEN
  displayName   String                // Human-readable: "Karaoke Highlight"
  description   String                // One-line description shown in picker
  previewCss    Json                  // CSS vars / props used by TypographyPreview component
  remotionConfig Json                 // Remotion animation params (easing, stagger, scale, etc.)
  sortOrder     Int          @default(0)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  lyricVideos   LyricVideo[]

  @@index([sortOrder])
}

model LyricVideo {
  id              String          @id @default(cuid())

  // Owner — null for guests
  userId          String?
  guestEmail      String?
  guestName       String?

  // Source track
  trackId         String?          // linked IndieThis Track (subscribers only)
  trackTitle      String
  trackDuration   Int              // seconds
  audioUrl        String           // uploaded or pulled from Track.fileUrl
  coverArtUrl     String?          // used as Kling image seed + color extraction

  // Mode
  mode            String           // QUICK | DIRECTOR

  // Typography
  typographyStyleId String?
  typographyStyle   TypographyStyle? @relation(fields: [typographyStyleId], references: [id])

  // Style
  colorPalette    Json?            // { primary, secondary, accent } extracted from cover art
  visionPrompt    String?          // user's free-text direction

  // Song analysis
  songStructure   Json?            // SongAnalysis object from song-analyzer
  bpm             Int?
  musicalKey      String?
  energy          Float?
  lyrics          String?
  lyricTimestamps Json?            // LyricWord[]: { word, start, end }[]

  // Director Mode
  creativeBrief   Json?            // Claude-generated creative brief
  sectionPlan     Json?            // SectionPlan[]: { sectionIndex, type, lyrics, typographyOverride, backgroundPrompt }
  conversationLog Json?            // ChatMessage[]: { role, content, createdAt }

  // Generation output
  backgroundScenes Json?           // BackgroundScene[]: { sectionIndex, videoUrl, prompt, startTime, endTime }
  finalVideoUrl   String?
  thumbnailUrl    String?

  // Job state
  status          String           @default("PENDING")
  // PENDING → ANALYZING → GENERATING → STITCHING → COMPLETE | FAILED
  progress        Int              @default(0)   // 0-100
  currentStep     String?
  errorMessage    String?

  // Billing
  stripePaymentId String?
  amount          Int              // cents paid (0 for included subscription credits)

  // Non-subscriber conversion tracking (mirrors MusicVideo / CoverArtJob pattern)
  conversionStep      Int          @default(0)
  conversionNextAt    DateTime?
  conversionPromoCode String?
  conversionAnyOpened Boolean      @default(false)
  conversionDone      Boolean      @default(false)
  abandonedCartSent   Boolean      @default(false)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User?            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([guestEmail])
  @@index([status])
  @@index([createdAt])
}

// ─── Release Board ─────────────────────────────────────────────────────────────

model Release {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  title            String                // album / single / EP name
  trackIds         Json                  // String[] — track IDs in this release
  coverArtJobId    String?               // linked CoverArtJob id
  musicVideoId     String?               // linked MusicVideo id
  lyricVideoId     String?               // linked LyricVideo id
  canvasVideoId    String?               // track ID whose canvasVideoUrl is used
  masteredTrackId  String?               // linked mastered track id
  releaseDate      DateTime?             // planned release date
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([updatedAt])
}

// ─── AI Mix & Master Studio ────────────────────────────────────────────────────

model MasteringJob {
  id                      String    @id @default(cuid())
  userId                  String?
  user                    User?     @relation(fields: [userId], references: [id])

  // Guest fields
  guestEmail              String?
  guestName               String?

  // Mode
  mode                    String    // MIX_AND_MASTER | MASTER_ONLY
  tier                    String    // STANDARD | PREMIUM | PRO

  // Input
  inputType               String    // STEMS | STEREO
  inputFileUrl            String?   // stereo mix URL (MASTER_ONLY)
  stems                   Json?     // array of stem objects (MIX_AND_MASTER)

  // Track reference
  trackId                 String?   // linked IndieThis track (subscribers)

  // Configuration
  mood                    String?   // CLEAN | WARM | PUNCH | LOUD
  genre                   String?
  platforms               Json?     // target platform array
  referenceTrackUrl       String?
  referenceFileName       String?
  usedReference           Boolean   @default(false)

  // Processing
  status                  String    @default("PENDING")
  // PENDING | ANALYZING | SEPARATING | MIXING | MASTERING | COMPLETE | FAILED
  analysisData            Json?     // BPM, key, sections, per-stem analysis
  mixParameters           Json?     // Claude's per-stem processing decisions
  masterParameters        Json?     // Claude's mastering chain decisions

  // Versions — always 4: Clean, Warm, Punch, Loud
  versions                Json?     // [{ name, lufs, url, waveformData }]
  selectedVersion         String?

  // Exports
  exports                 Json?     // [{ platform, lufs, format, url }]

  // Preview (30s, always free)
  previewUrl              String?
  previewExpiresAt        DateTime?

  // Revision (Pro tier only)
  revisionNote            String?
  revisionUsed            Boolean   @default(false)

  // Album mastering
  albumGroupId            String?

  // Mastering report (on-screen card, not PDF)
  reportData              Json?     // { finalLufs, truePeak, dynamicRange, loudnessPenalties }

  // Intelligence layer — input analysis snapshot
  inputLufs               Float?
  inputBpm                Float?
  inputKey                String?
  inputBalance            Json?     // { sub, low, mid, high }
  directionUsed           String?   // NLP prompt text applied to mastering

  // Direction dropdowns (v2 spec)
  vibeDirection           String?   // warm_full | bright_crisp | punchy_loud | lofi_vintage | natural_transparent
  platformTarget          String?   // spotify | apple_music | youtube | club_dj | radio | tiktok
  customDirection         String?   // Premium/Pro only — free-text notes
  mixDirection            String?   // stems mode: vocal_forward | bass_heavy | balanced_mix | drum_focused

  // Persistent file paths (signed URLs expire; paths are permanent)
  cleanFilePath           String?   // mastering/{jobId}/master_clean.wav
  warmFilePath            String?
  punchFilePath           String?
  loudFilePath            String?

  // Preview player data (waveform + per-version 30s clips)
  previewWaveform         Json?     // float[] 200 values — original track waveform peaks (0-1)
  versionWaveforms        Json?     // { clean: float[], warm: float[], punch: float[], loud: float[] }
  versionStats            Json?     // { clean: {lufs,peak,range,width}, warm: {...}, ... }
  originalPreviewPath     String?   // mastering/{jobId}/preview_original.wav
  previewCleanPath        String?   // mastering/{jobId}/preview_clean.wav
  previewWarmPath         String?
  previewPunchPath        String?
  previewLoudPath         String?

  // Guest access token relation
  accessToken             MasteringAccessToken?

  // Payment
  stripePaymentId         String?
  amount                  Int?      // cents

  // Conversion agents
  conversionStep          Int       @default(0)
  conversionNextAt        DateTime?
  conversionDone          Boolean   @default(false)
  conversionAnyOpened     Boolean   @default(false)
  conversionPromoCode     String?
  abandonedCartSent       Boolean   @default(false)
  followUpSent            Boolean   @default(false)  // true once mix-quality follow-up email sent (48h post-COMPLETE)

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([albumGroupId])
  @@index([guestEmail])
  @@index([createdAt])
}

model MasteringAlbumGroup {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])

  // Album metadata
  title           String
  artist          String?
  genre           String?
  mood            String?   // shared mood override
  naturalLanguagePrompt String?

  // Cross-track consistency snapshot (set after first track is analyzed)
  sharedLufsTarget  Float?    // target LUFS applied to all tracks
  sharedEqCurve     Json?     // shared EQ profile for consistency
  referenceTrackUrl String?   // optional reference track

  // Tracks are MasteringJob records linked by albumGroupId = this.id
  trackOrder      Json?     // [jobId, jobId, ...] — defines track sequence

  // Status
  status          String    @default("PENDING")
  // PENDING | PROCESSING | COMPLETE | FAILED
  completedTracks Int       @default(0)
  totalTracks     Int       @default(0)

  // Payment — per-track PaymentIntent, stored as JSON array
  paymentIds      Json?     // [{ jobId, stripePaymentId }]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model MasteringAccessToken {
  id        String       @id @default(cuid())
  jobId     String       @unique
  job       MasteringJob @relation(fields: [jobId], references: [id])
  token     String       @unique @default(cuid())
  email     String
  expiresAt DateTime
  createdAt DateTime     @default(now())

  @@index([token])
  @@index([email])
}

// ─── AI Mix Console ───────────────────────────────────────────────────────────

model MixJob {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])

  // Guest fields
  guestEmail      String?
  guestName       String?

  // Mode + tier
  mode            String    // VOCAL_BEAT | TRACKED_STEMS
  tier            String    // STANDARD | PREMIUM | PRO
  status          String    // PENDING | UPLOADING | SEPARATING | ANALYZING | AWAITING_DIRECTION | MIXING | PREVIEWING | QA_CHECK | COMPLETE | REVISING | FAILED

  // Input files
  inputFiles      Json      // [{ url, label, role }]
  referenceTrackUrl  String?
  referenceFileName  String?

  // Configuration
  genre           String?   // AUTO | HIP_HOP | TRAP | RNB | POP | ROCK | ELECTRONIC | ACOUSTIC | LO_FI | AFROBEATS | LATIN | COUNTRY | GOSPEL
  breathEditing   String?   // OFF | SUBTLE | CLEAN | TIGHT
  pitchCorrection String?   // OFF | SUBTLE | TIGHT | HARD
  delayStyle      String?   // OFF | SUBTLE | STANDARD | HEAVY
  mixVibe           String?   // CLEAN | POLISHED | DARK | BRIGHT | RAW
  reverbStyle       String?   // DRY | ROOM | PLATE | HALL | CATHEDRAL
  fadeOut           String?   // AUTO | 3S | 5S | 8S | NO
  vocalStylePreset  String?   // AUTO | CLEAN_NATURAL | LOFI_GRITTY | AIRY_SPACIOUS | RAW_UPFRONT
  beatPolish        Boolean   @default(false)  // Beat Polish add-on (+$19.99)
  customDirection   String?   // Premium/Pro free text

  // Direction
  directionUsed             String?   // Combined direction applied
  directionRecommendation   String?   // Claude's suggestion text shown to artist
  referenceNotes            String?   // Claude's reasoning about how reference influenced the mix

  // Analysis outputs
  analysisData        Json?   // { bpm, key, sections, stemAnalysis, roomReverb, pitchDeviation }
  lyrics              String? // Whisper transcription
  wordTimestamps      Json?   // [{ word, start, end }]
  delayThrows         Json?   // [{ word, start, end, type, feedback, section }]
  vocalClassification Json?   // [{ stemIndex, role, confidence }]
  inputQualityScore   Int?    // 0–100 quality gate score
  inputQualityNotes   String? // Human-readable quality warnings shown to artist
  mainVocalOverlap    Json?   // { overlapPercent, mode: "comp"|"stack"|"claude_decides" }

  // Mix parameters (Claude-decided)
  mixParameters   Json?     // Full chain params per stem
  sectionMap      Json?     // Section boundaries + per-section overrides

  // Output files — Standard (3 variations)
  cleanFilePath      String?
  polishedFilePath   String?
  aggressiveFilePath String?

  // Output files — Premium/Pro (single AI mix)
  mixFilePath     String?

  // Preview data
  previewWaveformOriginal Json?   // [200 floats] — vocal+beat original
  previewWaveformMixed    Json?   // { clean, polished, aggressive } or { mix }
  previewFilePaths        Json?   // { clean, polished, aggressive } or { mix, original }

  // QA gate results
  qaCheckResults  Json?     // { clipping, vocalAudibility, stereoBalance, freqBalance, phase, silentGaps }
  qaPassedAt      DateTime? // Timestamp when QA gate passed

  // Revision tracking
  revisionCount   Int       @default(0)
  maxRevisions    Int       @default(0)  // 0=Standard, 2=Premium, 3=Pro
  revisionHistory Json?     // [{ feedback, parametersApplied, timestamp }]

  // Payment
  stripePaymentId  String?
  amount           Int       @default(0)
  beatPolishAmount Int?      // Additional charge for Beat Polish add-on

  // Access token (guests)
  accessToken     MixAccessToken?

  // Guest file retention — cleared when guest converts to subscriber
  expiresAt       DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([guestEmail])
  @@index([status])
  @@index([expiresAt])
}

model MixAccessToken {
  id        String   @id @default(cuid())
  jobId     String   @unique
  job       MixJob   @relation(fields: [jobId], references: [id])
  token     String   @unique @default(cuid())
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model MasteringPreset {
  id            String   @id @default(cuid())
  name          String   @unique  // "Dark Trap", "Bright Pop", etc.
  genre         String            // HIP_HOP | POP | RNB | ELECTRONIC | ROCK | INDIE | LATIN | ACOUSTIC | JAZZ
  description   String
  mixProfile    Json              // per-stem default processing parameters
  masterProfile Json              // mastering chain defaults
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([genre])
  @@index([sortOrder])
}

// ─── Reference Analysis & Learning Engine ────────────────────────────────────
// Three-tier intelligence system: commercial library + user references + mix outcomes.
// See .claude/specs/indiethis-reference-analysis-engine-spec.md

model ReferenceProfile {
  id                    String   @id @default(cuid())
  source                String                       // 'commercial' | 'user_reference' | 'user_mix_outcome'
  sourceQuality         String?                      // 'lossless' | 'apple_music' | 'tidal' | 'spotify' | 'amazon_hd' | 'deezer' | 'youtube' | 'soundcloud' | 'other'
  sourceQualityWeight   Float    @default(1.0)       // 1.0 lossless / 0.9 spotify / 0.6 youtube / 0.5 soundcloud
  separationConfidence  Float?                       // 0.0–1.0 Demucs separation quality
  separationWeight      Float    @default(1.0)       // 1.0 clean / 0.7 acceptable / 0.3 poor
  genre                 String                       // HIP_HOP | TRAP | RNB | POP | ROCK | ELECTRONIC | ACOUSTIC | LO_FI | AFROBEATS | LATIN | COUNTRY | GOSPEL | NEO_SOUL
  subgenre              String?
  trackName             String?                      // human-readable label for admin UI
  artistName            String?
  fingerprintHash       String?                      // chromaprint fingerprint for dedup
  mixJobId              String?                      // links to MixJob if user_reference / user_mix_outcome
  profileData           Json                         // full analysis JSON
  qualityGatePassed     Boolean  @default(false)
  weight                Float    @default(1.0)       // base weight before source × separation modifiers
  isHoldout             Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@index([genre])
  @@index([source])
  @@index([fingerprintHash])
  @@index([mixJobId])
  @@index([genre, source])
}

model GenreTarget {
  id               String   @id @default(cuid())
  genre            String   @unique
  trackCount       Int      @default(0)
  commercialCount  Int      @default(0)
  userRefCount     Int      @default(0)
  userOutcomeCount Int      @default(0)
  pendingCount     Int      @default(0)            // event-driven recompute counter
  targetData       Json                            // aggregated mean/std/p25/p75 per param
  lastComputed     DateTime @default(now())

  @@index([genre])
}

model UserReferencePopularity {
  id              String   @id @default(cuid())
  fingerprintHash String   @unique
  genre           String
  uploadCount     Int      @default(1)
  firstSeen       DateTime @default(now())
  lastSeen        DateTime @default(now())
  autoPromoted    Boolean  @default(false)
  profileId       String?                          // optional FK to ReferenceProfile representing this song
  trackName       String?
  artistName      String?

  @@index([genre])
  @@index([uploadCount])
}

model MixOutcomeFeedback {
  id                   String   @id @default(cuid())
  mixJobId             String
  genre                String
  tier                 String?                    // STANDARD | PREMIUM | PRO
  inputQualityScore    Int?
  mixParamsUsed        Json?
  outputAnalysis       Json?
  outcome              String                     // 'downloaded' | 'revised' | 'abandoned'
  revisionNotes        Json?                      // array of { time, note }
  revisionKeywords     String[]                   // parsed keywords for aggregation
  revisionCount        Int      @default(0)
  variationSelected    String?
  timeToDownload       Int?                       // seconds from preview to download
  deviationFromTarget  Json?                      // z-scores per parameter
  qualifiesForLearning Boolean  @default(false)
  learningWeight       Float    @default(0)
  isHoldout            Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@index([mixJobId])
  @@index([genre])
  @@index([outcome])
  @@index([qualifiesForLearning])
}
