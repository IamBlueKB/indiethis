  name        String
  venue       String
  city        String
  date        DateTime
  time        String?
  ticketUrl   String?
  description String?
  createdAt   DateTime  @default(now())

  @@index([djProfileId])
}

model DJBookingInquiry {
  id          String    @id @default(cuid())
