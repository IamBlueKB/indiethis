  artistId   String
  name       String
  photoUrl   String?
  artistSlug String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  artist     User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
}

model ArtistPressItem {
  id        String   @id @default(cuid())
  artistId  String
  source    String
  title     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  artist    User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
}

// ─── Studio Portfolio Tracks ──────────────────────────────────────────────────

model StudioPortfolioTrack {
  id          String   @id @default(cuid())
  studioId    String
  title       String
  artistName  String
  audioUrl    String
  coverUrl    String?
  description String?
  artistSlug  String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  studio      Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
}

// ─── Studio Credits ───────────────────────────────────────────────────────────

model StudioCredit {
  id             String   @id @default(cuid())
  studioId       String
  artistName     String
  artistPhotoUrl String?
  projectName    String?
  artistSlug     String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  studio         Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
}

// ─── Studio Engineers ─────────────────────────────────────────────────────────

model StudioEngineer {
  id          String   @id @default(cuid())
  studioId    String
  name        String
  role        String
  photoUrl    String?
  specialties String[]
  bio         String?
  artistSlug  String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  studio      Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
}

// ─── Studio Equipment ─────────────────────────────────────────────────────────

model StudioEquipment {
  id        String            @id @default(cuid())
  studioId  String
  category  EquipmentCategory @default(OTHER)
  name      String
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())

  studio    Studio            @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
}

// ─── Promo Codes & Ambassadors ────────────────────────────────────────────────

model PromoCode {
  id                  String          @id @default(cuid())
  code                String          @unique
  type                PromoCodeType
  tier                SubscriptionTier?
  value               Float?
  durationDays        Int?
  durationMonths      Int?
  maxRedemptions      Int             @default(1)
  currentRedemptions  Int             @default(0)
  expiresAt           DateTime?
  isActive            Boolean         @default(true)
  notes               String?
  metadata            Json?           // AI_BUNDLE per-tool breakdown: {"art":10,"master":5,...}
  ambassadorId        String?
  ambassador          Ambassador?     @relation(fields: [ambassadorId], references: [id])
  redemptions         PromoRedemption[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([ambassadorId])
  @@index([code])
}

model PromoRedemption {
  id              String           @id @default(cuid())
  promoCodeId     String
  promoCode       PromoCode        @relation(fields: [promoCodeId], references: [id])
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  redeemedAt      DateTime         @default(now())
  convertedAt     DateTime?
  convertedTier   SubscriptionTier?
  upgradedAt      DateTime?
  upgradedToTier  SubscriptionTier?
  status          RedemptionStatus @default(ACTIVE)
  expiresAt       DateTime?
  graceUntil      DateTime?
  warningSentAt   DateTime?

  @@index([userId])
  @@index([promoCodeId])
  @@index([status, expiresAt])
}

model Ambassador {
  id                   String           @id @default(cuid())
  userId               String?          @unique
  user                 User?            @relation(fields: [userId], references: [id])
  name                 String
  email                String
  tier                 AmbassadorTier   @default(STANDARD)
  rewardType           RewardType       @default(FLAT_PER_CONVERSION)
  rewardValue          Float            @default(5.0)
  rewardDurationMonths Int?
  creditBalance        Float            @default(0)
  totalEarned          Float            @default(0)
  totalPaidOut         Float            @default(0)
  isActive             Boolean          @default(true)
  notes                String?
  stripeConnectId      String?
  promoCodes           PromoCode[]
  payouts              AmbassadorPayout[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([email])
}

model AmbassadorPayout {
  id             String     @id @default(cuid())
  ambassadorId   String
  ambassador     Ambassador @relation(fields: [ambassadorId], references: [id])
  amount         Float
  method         String
  stripePayoutId String?
  createdAt      DateTime   @default(now())

  @@index([ambassadorId])
}

model PlatformPricing {
  id        String   @id @default(cuid())
  key       String   @unique  // e.g. "PLAN_LAUNCH", "AI_COVER_ART"
  label     String            // Human-readable label
  value     Float             // Numeric value (dollars or percent)
  display   String            // Formatted display e.g. "$4.99" or "15%"
  category  String            // "subscriptions" | "ai_tools" | "platform_cuts"
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
  updatedBy String?           // admin email who last changed it
}

// ─── Stream Leases ─────────────────────────────────────────────────────────────

model StreamLease {
  id              String    @id @default(cuid())
  artistId        String
  beatId          String
  producerId      String
  trackTitle      String
  audioUrl        String
  coverUrl        String?
  isActive        Boolean   @default(true)
  activatedAt     DateTime  @default(now())
  cancelledAt     DateTime?
  trackHash       String?   // SHA-256 of the artist's uploaded finished song
  duplicateFlag   Boolean   @default(false) // true if trackHash matches another lease or beat
  duplicateFlagNote String? // details about the duplicate
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artist    User          @relation("ArtistStreamLeases",   fields: [artistId],   references: [id])
  beat      Track         @relation(fields: [beatId],        references: [id])
  producer  User          @relation("ProducerStreamLeases", fields: [producerId], references: [id])
  payments  StreamLeasePayment[]
  plays     StreamLeasePlay[]
  agreement        StreamLeaseAgreement?
  licenseDocuments LicenseDocument[]
}

model StreamLeasePlay {
  id            String      @id @default(cuid())
  streamLeaseId String
  viewerIpHash  String
  playedAt      DateTime    @default(now())

  streamLease StreamLease @relation(fields: [streamLeaseId], references: [id])
}

model StreamLeasePayment {
  id              String      @id @default(cuid())
  streamLeaseId   String
  artistId        String
  producerId      String
  totalAmount     Float       @default(1.00)
  producerAmount  Float       @default(0.70)
  platformAmount  Float       @default(0.30)
  stripeInvoiceId String
  paidAt          DateTime    @default(now())
  status          String      @default("PAID")  // "PAID" | "FAILED"
  failedAt        DateTime?
  failureReason   String?

  streamLease StreamLease @relation(fields: [streamLeaseId], references: [id])
}

// ─── Stream Lease Agreement System ─────────────────────────────────────────────

// Per-beat lease settings (overrides producer global settings)
model BeatLeaseSettings {
  id                  String   @id @default(cuid())
  beatId              String   @unique
  streamLeaseEnabled  Boolean  @default(true)
  maxStreamLeases     Int?                       // null = unlimited; enforced on lease creation
  creditFormat        String   @default("Prod. {producerName}")
  revocationPolicy    String   @default("A")   // A = 30-day notice, B = violation only, C = cannot revoke
  contentRestrictions String[] @default([])
  customRestriction   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  beat Track @relation(fields: [beatId], references: [id])
}

// Producer global defaults (applies to all beats unless per-beat override exists)
model ProducerLeaseSettings {
  id                  String   @id @default(cuid())
  producerId          String   @unique
  streamLeaseEnabled  Boolean  @default(true)
  creditFormat        String   @default("Prod. {producerName}")
  revocationPolicy    String   @default("A")
  contentRestrictions String[] @default([])
  customRestriction   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  producer User @relation(fields: [producerId], references: [id])
}

// Snapshot of the agreement at time of signing — immutable record of terms in effect
model StreamLeaseAgreement {
  id               String      @id @default(cuid())
  streamLeaseId    String      @unique
  agreementHtml    String      // full rendered agreement at time of signing
  producerTerms    Json        // snapshot of producer settings at time of signing
  artistAcceptedAt DateTime
  createdAt        DateTime    @default(now())

  streamLease StreamLease @relation(fields: [streamLeaseId], references: [id])
}

model StreamLeaseBookmark {
  id        String   @id @default(cuid())
  artistId  String
  beatId    String
  createdAt DateTime @default(now())

  artist User  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  beat   Track @relation(fields: [beatId],   references: [id], onDelete: Cascade)

  @@unique([artistId, beatId])
}

model ProducerProfile {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  displayName              String?  // producer alias if different from artist name
  bio                      String?  // producer-specific bio shown on beats section of artist page
  defaultLeasePrice        Float?
  defaultNonExclusivePrice Float?
  defaultExclusivePrice    Float?
  separatePayoutEnabled    Boolean  @default(false)
  producerStripeConnectId  String?  // Stripe Connect account ID for separate producer payouts
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── License & Receipt Vault ────────────────────────────────────────────────

enum LicenseSource {
  SPLICE
  SUNO
  UDIO
  SOUNDRAW
  LANDR
  TRACKLIB
  LOOPCLOUD
  AI_GENERATION
  CUSTOM
  SAMPLE_CLEARANCE
  WORK_FOR_HIRE
  OTHER
}

model LicenseDocument {
  id            String        @id @default(cuid())
  userId        String
  title         String        // user-provided name: "Splice License - Midnight Piano Loop"
  fileUrl       String        // uploaded file URL (PDF, PNG, JPG)
  fileType      String        // pdf, png, jpg
  source        LicenseSource // where it came from
  notes         String?       // optional user notes

  // Linkage — what content this document is attached to
  trackId       String?       // if attached to a track or beat (beats are Tracks in this schema)
  streamLeaseId String?       // if attached to a stream lease
  aiJobId       String?       // if attached to an AI tool output

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user        User         @relation(fields: [userId],        references: [id])
  track       Track?       @relation(fields: [trackId],       references: [id])
  streamLease StreamLease? @relation(fields: [streamLeaseId], references: [id])
  aiJob       AIJob?       @relation(fields: [aiJobId],       references: [id])

  @@index([userId])
  @@index([trackId])
  @@index([streamLeaseId])
  @@index([aiJobId])
}

// ─── Session Notes / Project Tracker ─────────────────────────────────────────

model SessionNote {
  id               String            @id @default(cuid())
  bookingSessionId String
  studioId         String
  artistId         String
  title            String
  body             String            @db.Text
  status           SessionNoteStatus @default(DRAFT)
  isShared         Boolean           @default(false)  // true = visible to artist
  artistFeedback   String?           @db.Text
  feedbackAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  bookingSession   BookingSession    @relation(fields: [bookingSessionId], references: [id], onDelete: Cascade)
  studio           Studio            @relation(fields: [studioId], references: [id])
  artist           User              @relation(fields: [artistId], references: [id])
  attachments      SessionNoteAttachment[]

  @@index([bookingSessionId])
  @@index([studioId])
  @@index([artistId])
}

model SessionNoteAttachment {
  id            String      @id @default(cuid())
  sessionNoteId String
  fileUrl       String
  fileName      String
  fileSize      Int?
  createdAt     DateTime    @default(now())

  sessionNote   SessionNote @relation(fields: [sessionNoteId], references: [id], onDelete: Cascade)

  @@index([sessionNoteId])
}

// ─── Split Sheets / Payment Splitting ────────────────────────────────────────

model SplitSheet {
  id          String           @id @default(cuid())
  trackId     String           @unique
  createdById String
  status      SplitSheetStatus @default(PENDING)
  documentUrl String?          // generated PDF URL once all parties agree
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  track       Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("SplitSheetCreator", fields: [createdById], references: [id])
  splits      Split[]

  @@index([createdById])
}

model Split {
  id              String    @id @default(cuid())
  splitSheetId    String
  userId          String?
  name            String
  email           String
  role            SplitRole
  percentage      Float
  reviewToken     String    @unique @default(cuid())
  agreedAt        DateTime?
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text
  ipHash          String?   // hashed IP captured at agreement time
  stripeConnectId String?
  pendingBalance  Float     @default(0)
  totalPaid       Float     @default(0)
  createdAt       DateTime  @default(now())

  splitSheet      SplitSheet   @relation(fields: [splitSheetId], references: [id], onDelete: Cascade)
  user            User?        @relation("UserSplits", fields: [userId], references: [id])
  payments        SplitPayment[]

  @@index([splitSheetId])
  @@index([userId])
}

model SplitPayment {
  id               String   @id @default(cuid())
  splitId          String
  amount           Float
  sourceType       String   // MERCH_SALE, TIP, STREAM_LEASE, LICENSE_SALE, MUSIC_SALE
  sourceId         String
  stripeTransferId String?
  paidAt           DateTime @default(now())

  split            Split    @relation(fields: [splitId], references: [id])

  @@index([splitId])
}

// ─── Release Planner ──────────────────────────────────────────────────────────

enum ReleasePlanStatus {
  PLANNING
  IN_PROGRESS
  LAUNCHED
  CANCELLED
}

enum TaskCategory {
  CREATIVE
  DISTRIBUTION
  MARKETING
  MERCH
  ADMIN
}

enum TaskActionType {
  AI_COVER_ART
  AI_VIDEO
  AI_MASTERING
  AI_LYRIC_VIDEO
  AI_PRESS_KIT
  AI_AR_REPORT
  PRE_SAVE_CAMPAIGN
  EMAIL_BLAST
  SMS_BROADCAST
  MERCH_LAUNCH
  UPLOAD_TRACK
  SPLIT_SHEET
  CUSTOM
}

model ReleasePlan {
  id          String            @id @default(cuid())
  artistId    String
  trackId     String?
  releaseId   String?
  title       String
  releaseDate DateTime
  status      ReleasePlanStatus @default(PLANNING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  artist  User           @relation(fields: [artistId], references: [id], onDelete: Cascade)
  track   Track?         @relation(fields: [trackId], references: [id], onDelete: SetNull)
  release ArtistRelease? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  tasks   ReleasePlanTask[]

  @@index([artistId])
}

model ReleasePlanTask {
  id            String          @id @default(cuid())
  releasePlanId String
  title         String
  description   String?         @db.Text
  category      TaskCategory
  dueDate       DateTime
  sortOrder     Int
  isCompleted   Boolean         @default(false)
  completedAt   DateTime?
  actionType    TaskActionType?
  actionUrl     String?
  linkedItemId  String?
  createdAt     DateTime        @default(now())

  releasePlan ReleasePlan @relation(fields: [releasePlanId], references: [id], onDelete: Cascade)

  @@index([releasePlanId])
}

// ─── Explore Page ─────────────────────────────────────────────────────────────

model ExploreFeatureCard {
  id          String    @id @default(cuid())
  type        String    @default("ANNOUNCEMENT") // ARTIST_SPOTLIGHT | BEAT_PACK | STUDIO_PROMO | AI_SHOWCASE | ANNOUNCEMENT
  headline    String
  description String?   @db.Text
  imageUrl    String?
  gradient    String?   // fallback CSS gradient string
  ctaText     String    @default("Learn More")
  ctaUrl      String
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  linkedArtistId String?
  linkedArtist   User?   @relation("FeaturedArtist", fields: [linkedArtistId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder])
}

model RecentPlay {
  id       String   @id @default(cuid())
  userId   String
  trackId  String
  playedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
  @@index([trackId])
}

// ─── Onboarding Email Log ─────────────────────────────────────────────────────

model OnboardingEmailLog {
  id        String   @id @default(cuid())
  userId    String
  emailType String   // WELCOME | DAY1_TRACK | DAY3_AI | DAY5_PAGE | DAY7_FANS | DAY14_DISCOVER | DAY30_MILESTONE
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, emailType])
  @@index([userId])
}

model ReEngagementEmailLog {
  id        String   @id @default(cuid())
  userId    String
  emailType String   // 7DAY | 14DAY | 30DAY | 45DAY
  cycleKey  String   // ISO date string of cycle start (lastLoginAt snapshot) — reset when user logs back in
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, emailType, cycleKey])
  @@index([userId])
}

// Temporary signup data stored before Stripe payment completes.
// Deleted once the account is created. Expires after 24 hours.
model PendingSignup {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  role            Role
  signupPath      String?
  referredByCode  String?
  affiliateId     String?
  promoCode       String?
  source          String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  landingPage     String?
  firstVisitAt    DateTime?
  stripeSessionId String?   @unique
  tier            String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
}
