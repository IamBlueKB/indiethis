// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business Models ──────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  emailVerified    DateTime?
  phone            String?
  passwordHash     String
  role             Role     @default(ARTIST)
  name             String
  artistName       String?
  bio              String?
  photo            String?
  instagramHandle  String?
  tiktokHandle     String?
  youtubeChannel   String?
  spotifyUrl       String?
  appleMusicUrl    String?
  stripeCustomerId String?
  stripeConnectId      String?
  passwordResetToken   String?   @unique
  passwordResetExpiry  DateTime?
  igFollowClaimed  Boolean  @default(false)
  referralCode         String?             @unique
  referredById         String?
  referredByCode       String?
  referralRewardTier   ReferralRewardTier  @default(NONE)
  artistSlug           String?             @unique
  isComped         Boolean   @default(false)
  compExpiresAt    DateTime?
  isSuspended      Boolean   @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastLoginAt      DateTime?
  city             String?
  genres           String[]
  soundcloudUrl    String?
  signupPath       String?
  onboardingStep   Int       @default(0)
  planSelectedAt           DateTime?
  setupCompletedAt         DateTime?
  firstVisitAt             DateTime?
  firstContentAt           DateTime?
  pagePublishedAt          DateTime?
  autoSigninToken          String?   @unique
  autoSigninTokenExpiresAt DateTime?
  accounts         Account[]
  subscription     Subscription?
  tracks           Track[]
  sessions         BookingSession[]
  aiGenerations    AIGeneration[]
  merchProducts    MerchProduct[]
  artistSite       ArtistSite?
  deliveredFiles   DeliveredFile[]
  studios          StudioArtist[]
  ownedStudios     Studio[]
  payments         Payment[]
  notifications    Notification[]
  receipts         Receipt[]
  referredBy       User?            @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]           @relation("Referrals")
  producedPreviews   BeatPreview[]      @relation("ProducerPreviews")
  receivedPreviews   BeatPreview[]      @relation("ArtistPreviews")
  producerLicenses   BeatLicense[]      @relation("ProducerLicenses")
  artistLicenses     BeatLicense[]      @relation("ArtistLicenses")
  youtubeReferences  YoutubeReference[]
  preSaveCampaigns   PreSaveCampaign[]
  artistVideos       ArtistVideo[]
  youtubeSync        YouTubeSync?
  artistShows        ArtistShow[]
  showInterests      ShowInterest[]
  artistSupports          ArtistSupport[]
  fanContacts             FanContact[]
  fanScores               FanScore[]
  broadcastLogs           BroadcastLog[]
  artistBookingInquiries  ArtistBookingInquiry[]
  artistPageViews         PageView[]         @relation("ArtistPageViews")
  artistTrackPlays        TrackPlay[]        @relation("ArtistTrackPlays")
  artistLinkClicks        LinkClick[]        @relation("ArtistLinkClicks")
  referralsGiven     Referral[]         @relation("ReferrerReferrals")
  referralReceived   Referral?          @relation("ReferredReferrals")
  affiliate          Affiliate?
  affiliateReferral  AffiliateReferral? @relation("AffiliateReferredUser")
  attribution        UserAttribution?
  artistReleases     ArtistRelease[]
  artistPhotos       ArtistPhoto[]
  artistTestimonials ArtistTestimonial[]
  artistCollaborators ArtistCollaborator[]
  artistPressItems   ArtistPressItem[]
  promoRedemptions     PromoRedemption[]
  ambassador           Ambassador?
  artistStreamLeases    StreamLease[]          @relation("ArtistStreamLeases")
  producerStreamLeases  StreamLease[]          @relation("ProducerStreamLeases")
  producerLeaseSettings ProducerLeaseSettings?
  streamLeaseBookmarks  StreamLeaseBookmark[]
  producerProfile       ProducerProfile?
  licenseDocuments      LicenseDocument[]
  artistSessionNotes    SessionNote[]
  splitSheetsCreated    SplitSheet[]      @relation("SplitSheetCreator")
  splits                Split[]           @relation("UserSplits")
  releasePlans          ReleasePlan[]
  recentPlays           RecentPlay[]
  featuredCards         ExploreFeatureCard[] @relation("FeaturedArtist")
  onboardingEmails      OnboardingEmailLog[]
  reEngagementEmails    ReEngagementEmailLog[]
}

model Studio {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  address      String?
  phone        String?
  email        String?
  description  String?
  hours        String?
  streetAddress        String?
  city                 String?
  state                String?
  zipCode              String?
  instagram            String?
  tiktok               String?
  youtube              String?
  facebook             String?
  cashAppHandle        String?
  zelleHandle          String?
  paypalHandle         String?
  venmoHandle          String?
  stripePaymentsEnabled Boolean @default(false)
  photos       String[]
  logo         String?
  heroImage    String?
  tagline      String?
  services     String[]
  servicesJson String?
  testimonials String?
  twitter      String?
  isEnterprise Boolean  @default(false)
  studioTier    StudioTier     @default(PRO)
  template      StudioTemplate @default(CLASSIC)
  accentColor   String?
  customDomain  String?
  isPublished   Boolean        @default(false)
  bio           String?
  logoUrl       String?
  galleryImages Json?
  studioHours   Json?
  hoursNote     String?
  socialLinks   Json?
  paymentMethods Json?
  featuredArtists Json?
  pageConfig               Json?
  tierOverride             String?
  moderationStatus         ModerationStatus @default(CLEAN)
  moderationReason         String?
  moderationScannedAt      DateTime?
  onboardingCompleted      Boolean   @default(false)
  generationsUsedThisMonth Int       @default(0)
  generationResetDate      DateTime?
  referralCredits          Float     @default(0)
  referralCreditHistory    Json?
  emailSequenceEnabled     Boolean   @default(false)
  averageSessionRate       Float     @default(150)
  ownerId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner              User              @relation(fields: [ownerId], references: [id])
  artists            StudioArtist[]
  sessions           BookingSession[]
  deliveredFiles     DeliveredFile[]
  emailCampaigns     EmailCampaign[]
  contacts           Contact[]
  intakeLinks        IntakeLink[]
  intakeSubmissions  IntakeSubmission[]
  quickSends         QuickSend[]
  activityLog        ActivityLog[]
  invoices           Invoice[]
  contactSubmissions ContactSubmission[]
  generationLogs     GenerationLog[]
  pageViews          PageView[]
  scheduledEmails    ScheduledEmail[]
  portfolioTracks    StudioPortfolioTrack[]
  credits            StudioCredit[]
  engineers          StudioEngineer[]
  equipment          StudioEquipment[]
  sessionNotes       SessionNote[]
}

model StudioArtist {
  id       String   @id @default(cuid())
  studioId String
  artistId String
  joinedAt DateTime @default(now())

  studio   Studio   @relation(fields: [studioId], references: [id])
  artist   User     @relation(fields: [artistId], references: [id])

  @@unique([studioId, artistId])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  tier                   SubscriptionTier
  status                 SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId   String?
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  aiVideoCreditsUsed     Int                @default(0)
  aiVideoCreditsLimit    Int
  aiArtCreditsUsed       Int                @default(0)
  aiArtCreditsLimit      Int
  aiMasterCreditsUsed    Int                @default(0)
  aiMasterCreditsLimit   Int
  lyricVideoCreditsUsed  Int                @default(0)
  lyricVideoCreditsLimit Int
  aarReportCreditsUsed   Int                @default(0)
  aarReportCreditsLimit  Int
  pressKitCreditsUsed    Int                @default(0)
  pressKitCreditsLimit   Int                @default(0)
  smsBroadcastsUsed      Int                @default(0)
  cancelReason           String?
  canceledAt             DateTime?
  streamLeaseGraceUntil  DateTime?          // set when invoice.payment_failed; cleared on invoice.paid
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user                   User               @relation(fields: [userId], references: [id])
}

// Named BookingSession to avoid conflict with NextAuth's Session model
model BookingSession {
  id            String        @id @default(cuid())
  studioId      String
  artistId      String
  contactId     String?
  dateTime      DateTime
  duration      Int?
  sessionType   String?
  status        SessionStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod?
  intakeData    Json?
  notes         String?
  engineerNotes String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  studio         Studio          @relation(fields: [studioId], references: [id])
  artist         User            @relation(fields: [artistId], references: [id])
  contact        Contact?        @relation(fields: [contactId], references: [id])
  deliveredFiles DeliveredFile[]
  sessionNotes   SessionNote[]
}

model Track {
  id          String      @id @default(cuid())
  artistId    String
  title       String
  description String?
  fileUrl     String
  coverArtUrl String?
  price       Float?
  status      TrackStatus @default(DRAFT)
  plays       Int         @default(0)
  downloads   Int         @default(0)
  earnings    Float       @default(0)
  projectName String?
  releaseId   String?
  bpm         Int?
  musicalKey  String?
  audioHash         String?  // SHA-256 of the beat file — for duplicate detection
  totalLicenses     Int      @default(0)  // count of all license sales
  totalStreamLeases Int      @default(0)  // count of active stream leases
  totalPlays        Int      @default(0)  // sum of plays across all stream-leased tracks
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  artist           User               @relation(fields: [artistId], references: [id])
  release          ArtistRelease?     @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  beatPreviews     BeatPreview[]
  beatLicenses     BeatLicense[]
  trackPlays       TrackPlay[]
  streamLeases          StreamLease[]
  beatLeaseSettings     BeatLeaseSettings?
  streamLeaseBookmarks  StreamLeaseBookmark[]
  licenseDocuments      LicenseDocument[]
  splitSheet            SplitSheet?
  releasePlans          ReleasePlan[]
  genre                 String?
  recentPlays           RecentPlay[]
  videoTrackLinks       ArtistVideo[]  @relation("VideoTrackLink")
  videoBeatLinks        ArtistVideo[]  @relation("VideoBeatLink")
}

model DeliveredFile {
  id               String         @id @default(cuid())
  sessionId        String?
  artistId         String
  studioId         String
  contactId        String?
  fileUrl          String
  fileName         String
  notes            String?
  notificationSent Boolean        @default(false)
  deliveredAt      DateTime       @default(now())

  session          BookingSession? @relation(fields: [sessionId], references: [id])
  artist           User            @relation(fields: [artistId], references: [id])
  studio           Studio          @relation(fields: [studioId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])
}

model MerchProduct {
  id           String      @id @default(cuid())
  artistId     String
  title        String
  description  String?
  imageUrl     String
  basePrice    Float
  artistMarkup Float
  productType  ProductType
  variants     Json?
  isActive     Boolean     @default(true)
  printfulId   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  artist          User          @relation(fields: [artistId], references: [id])
  orders          MerchOrder[]
  videoMerchLinks ArtistVideo[] @relation("VideoMerchLink")
}

model MerchOrder {
  id                String            @id @default(cuid())
  merchProductId    String
  artistId          String
  buyerEmail        String
  quantity          Int
  totalPrice        Float
  platformCut       Float
  artistEarnings    Float
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  trackingNumber    String?
  stripePaymentId   String?
  createdAt         DateTime          @default(now())

  merchProduct      MerchProduct      @relation(fields: [merchProductId], references: [id])
}

model AIGeneration {
  id         String             @id @default(cuid())
  artistId   String
  type       AIGenerationType
  inputData  Json?
  outputData Json?
  outputUrl  String?
  creditUsed Boolean            @default(false)
  paymentId  String?
  status     AIGenerationStatus @default(QUEUED)
  createdAt  DateTime           @default(now())

  artist     User               @relation(fields: [artistId], references: [id])
}

model ArtistSite {
  id                String             @id @default(cuid())
  artistId          String             @unique
  template          ArtistSiteTemplate @default(TEMPLATE_1)
  colorScheme       Json?
  heroImage         String?
  bioContent        String?
  showMusic         Boolean            @default(true)
  showVideos        Boolean            @default(true)
  showMerch         Boolean            @default(true)
  showContact       Boolean            @default(false)
  followGateEnabled Boolean            @default(false)
  pwywEnabled       Boolean            @default(false)
  credentials       String[]
  bookingRate       Float?
  customDomain      String?
  isPublished       Boolean            @default(false)
  draftMode         Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  pinnedMessage         String?
  pinnedActionText      String?
  pinnedActionUrl       String?
  activityTickerEnabled Boolean            @default(false)

  genre                 String?
  role                  String?
  city                  String?
  soundcloudUrl         String?

  artist            User               @relation(fields: [artistId], references: [id])
}

model YoutubeReference {
  id           String   @id @default(cuid())
  artistId     String
  url          String
  videoId      String
  title        String
  thumbnailUrl String
  authorName   String?
  projectTag   String?
  folder       String?
  createdAt    DateTime @default(now())

  artist  User @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  type            String
  amount          Float
  method          String?
  status          String
  stripePaymentId String?
  metadata        Json?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model EmailCampaign {
  id              String    @id @default(cuid())
  studioId        String
  subject         String
  body            String
  recipientFilter Json?
  recipientCount  Int       @default(0)
  openCount       Int       @default(0)
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  attachmentUrls  String[]

  studio          Studio    @relation(fields: [studioId], references: [id])
}

// ─── Notification Center ──────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Studio CRM ───────────────────────────────────────────────────────────────

model Contact {
  id              String        @id @default(cuid())
  studioId        String
  name            String
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  photoUrl        String?
  instagramHandle String?
  genre           String?
  notes           String?
  source               ContactSource @default(MANUAL)
  totalSpent           Float         @default(0)
  lastSessionDate      DateTime?
  referredToIndieThis  Boolean       @default(false)
  convertedToBooking   Boolean       @default(false)
  convertedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  studio             Studio            @relation(fields: [studioId], references: [id])
  sessions           BookingSession[]
  deliveredFiles     DeliveredFile[]
  intakeSubmissions  IntakeSubmission[]
  activityLog        ActivityLog[]
  invoices           Invoice[]
}

model ActivityLog {
  id          String          @id @default(cuid())
  contactId   String
  studioId    String
  type        ActivityLogType
  description String
  metadata    Json?
  createdAt   DateTime        @default(now())

  contact     Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  studio      Studio          @relation(fields: [studioId], references: [id])
}

// ─── Intake Form Links ────────────────────────────────────────────────────────

model IntakeLink {
  id        String    @id @default(cuid())
  studioId  String
  contactId String?
  token       String    @unique
  name        String?
  email       String?
  phone       String?
  sessionDate DateTime?
  sessionTime String?
  endTime     String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  studio     Studio           @relation(fields: [studioId], references: [id])
  submission IntakeSubmission?
}

model IntakeSubmission {
  id                    String   @id @default(cuid())
  intakeLinkId          String   @unique
  studioId              String
  contactId             String?
  artistName            String
  genre                 String?
  projectDesc           String?
  youtubeLinks          String[]
  fileUrls              String[]
  photoUrl              String?
  notes                 String?
  bpmDetected           Int?
  keyDetected           String?
  instagram             String?
  tiktok                String?
  youtubeHandle         String?
  paymentMethod         String?
  depositPaid           Boolean  @default(false)
  depositAmount         Float?
  aiVideoRequested      Boolean  @default(false)
  convertedToBookingId  String?
  createdAt             DateTime @default(now())

  intakeLink  IntakeLink @relation(fields: [intakeLinkId], references: [id])
  studio      Studio     @relation(fields: [studioId], references: [id])
  contact     Contact?   @relation(fields: [contactId], references: [id])
}

// ─── Quick Send (WeTransfer-style) ────────────────────────────────────────────

model QuickSend {
  id             String    @id @default(cuid())
  studioId       String
  contactId      String?
  senderName     String
  recipientEmail String
  recipientPhone String?
  fileUrls       String[]
  message        String?
  token                String    @unique
  expiresAt            DateTime
  downloadedAt         DateTime?
  sendFollowUpSequence Boolean   @default(false)
  createdAt            DateTime  @default(now())

  studio   Studio   @relation(fields: [studioId], references: [id])
}

// ─── Beat Preview + Licensing ─────────────────────────────────────────────────

model BeatPreview {
  id             String            @id @default(cuid())
  producerId     String
  artistId       String?
  trackId        String
  expiresAt      DateTime
  isDownloadable Boolean           @default(false)
  status         BeatPreviewStatus @default(PENDING)
  createdAt      DateTime          @default(now())

  producer      User          @relation("ProducerPreviews", fields: [producerId], references: [id])
  artist        User?         @relation("ArtistPreviews", fields: [artistId], references: [id])
  track         Track         @relation(fields: [trackId], references: [id])
  licenses      BeatLicense[]
}

model BeatLicense {
  id            String      @id @default(cuid())
  beatPreviewId String
  trackId       String
  producerId    String
  artistId      String
  licenseType   LicenseType
  customTerms   String?
  price         Float
  status        String      @default("ACTIVE")
  pdfUrl        String?
  createdAt     DateTime    @default(now())

  beatPreview BeatPreview @relation(fields: [beatPreviewId], references: [id])
  track       Track       @relation(fields: [trackId], references: [id])
  producer    User        @relation("ProducerLicenses", fields: [producerId], references: [id])
  artist      User        @relation("ArtistLicenses", fields: [artistId], references: [id])
}

// ─── Receipts ──────────────────────────────────────────────────────────────────

model Receipt {
  id              String      @id @default(cuid())
  userId          String
  type            ReceiptType
  description     String
  amount          Float
  paymentMethod   String?
  stripePaymentId String?
  pdfUrl          String?
  createdAt       DateTime    @default(now())

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Studio Invoices ───────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  studioId       String
  contactId      String
  invoiceNumber  Int
  lineItems      Json
  subtotal       Float
  tax            Float         @default(0)
  taxRate        Float         @default(0)
  total          Float
  dueDate        DateTime
  status         InvoiceStatus @default(DRAFT)
  paymentMethod  String?
  paidAt         DateTime?
  remindersSent  Int           @default(0)
  notes          String?
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  studio   Studio   @relation(fields: [studioId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@unique([studioId, invoiceNumber])
}

// ─── Studio Public Page Contact Submissions ───────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  email     String
  phone     String?
  message   String
  source    String   @default("PUBLIC_PAGE")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

model GenerationLog {
  id             String         @id @default(cuid())
  studioId       String
  template       StudioTemplate
  configSnapshot Json
  createdAt      DateTime       @default(now())
  wasPaid        Boolean        @default(false)

  studio         Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

// ─── Page View Tracking ───────────────────────────────────────────────────────

model PageView {
  id       String   @id @default(cuid())
  studioId String?
  artistId String?
  viewedAt DateTime @default(now())
  ipHash   String
  referrer String?  // "qr" when fan arrives via QR code scan

  studio   Studio?  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  artist   User?    @relation("ArtistPageViews", fields: [artistId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([studioId, viewedAt])
  @@index([studioId, ipHash, viewedAt])
  @@index([artistId])
  @@index([artistId, viewedAt])
  @@index([artistId, ipHash, viewedAt])
  @@index([artistId, referrer])
}

// ─── Artist Track Plays ───────────────────────────────────────────────────────

model TrackPlay {
  id       String   @id @default(cuid())
  trackId  String
  artistId String
  ipHash   String
  playedAt DateTime @default(now())

  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist   User     @relation("ArtistTrackPlays", fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([trackId])
  @@index([artistId, playedAt])
  @@index([trackId, ipHash, playedAt])
}

// ─── Artist Link Clicks ───────────────────────────────────────────────────────

model LinkClick {
  id        String   @id @default(cuid())
  artistId  String
  platform  String
  trackId   String?
  clickedAt DateTime @default(now())

  artist    User     @relation("ArtistLinkClicks", fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([artistId, platform])
  @@index([artistId, clickedAt])
}

// ─── AI Feedback & Learning Models ───────────────────────────────────────────

model GenerationFeedback {
  id              String   @id @default(cuid())
  pageType        PageType
  ownerId         String
  generationLogId String?
  sectionType     String
  fieldChanged    String
  aiOriginalValue String   @db.Text
  userEditedValue String   @db.Text
  createdAt       DateTime @default(now())

  @@index([ownerId])
  @@index([fieldChanged])
  @@index([sectionType])
}

model AIInsightsLog {
  id          String      @id @default(cuid())
  insightType InsightType
  referenceId String?
  input       String      @db.Text
  output      String      @db.Text
  actionTaken String?
  accuracy    Boolean?
  createdAt   DateTime    @default(now())

  @@index([insightType])
  @@index([referenceId])
}

// ─── Unified AI Job Queue ──────────────────────────────────────────────────────

model AIJob {
  id              String       @id @default(cuid())
  type            AIJobType
  status          AIJobStatus  @default(QUEUED)
  triggeredBy     AIJobTrigger
  triggeredById   String
  artistId        String?
  studioId        String?
  inputData       Json?
  outputData      Json?
  provider        String
  costToUs        Float?
  priceCharged    Float?
  errorMessage    String?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  licenseDocuments LicenseDocument[]

  @@index([triggeredById])
  @@index([artistId])
  @@index([studioId])
  @@index([status])
  @@index([type])
}

// ─── Email Sequence Scheduler ─────────────────────────────────────────────────

model ScheduledEmail {
  id           String               @id @default(cuid())
  studioId     String
  contactId    String?
  contactEmail String
  quickSendId  String?
  sequenceStep SequenceStep
  subject      String               @default("")
  body         String               @default("")
  scheduledFor DateTime
  status       ScheduledEmailStatus @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime             @default(now())

  studio       Studio               @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([status, scheduledFor])
  @@index([quickSendId])
}

// ─── Referral Tracking ────────────────────────────────────────────────────────

model Referral {
  id              String    @id @default(cuid())
  referrerUserId  String
  referredUserId  String    @unique          // a user can only be referred once
  isActive        Boolean   @default(false)  // true while referred user has active subscription
  activatedAt     DateTime?                  // when isActive first became true
  deactivatedAt   DateTime?                  // when isActive last became false (churn)
  createdAt       DateTime  @default(now())

  referrer        User      @relation("ReferrerReferrals", fields: [referrerUserId], references: [id])
  referred        User      @relation("ReferredReferrals", fields: [referredUserId],  references: [id])

  @@index([referrerUserId])
  @@index([isActive])
}

// ─── Affiliate Program ────────────────────────────────────────────────────────

model Affiliate {
  id                        String          @id @default(cuid())
  /// Linked account — nullable so non-account applicants can apply; set on approval or on account creation
  userId                    String?         @unique
  /// Applicant identity captured from the form (for pre-account applicants)
  applicantName             String
  applicantEmail            String
  status                    AffiliateStatus @default(PENDING)
  /// Landing page URL: indiethis.com/go/[customSlug] — generated at approval
  customSlug                String?         @unique
  /// Discount code their audience uses at signup (10% off first 3 months) — generated at approval
  discountCode              String?         @unique
  commissionRate            Float           @default(0.20)
  commissionDurationMonths  Int             @default(12)
  totalEarned               Float           @default(0)
  pendingPayout             Float           @default(0)
  /// Stripe Connect account for commission payouts
  stripeConnectAccountId    String?
  /// Raw application form data: socialLinks, audienceSize, creatorType, promotionPlan
  applicationData           Json?
  /// Payout history: Array<{ amount: number, date: string, stripeTransferId: string, status: 'paid' }>
  payoutHistory             Json?
  appliedAt                 DateTime        @default(now())
  approvedAt                DateTime?
  createdAt                 DateTime        @default(now())

  user      User?               @relation(fields: [userId], references: [id])
  referrals AffiliateReferral[]

  @@index([status])
  @@index([applicantEmail])
}

model AffiliateReferral {
  id                   String    @id @default(cuid())
  affiliateId          String
  referredUserId       String    @unique   // a user can only be referred by one affiliate
  /// Snapshot of commissionRate at time of referral (locked in)
  commissionRate       Float
  /// Months of commission remaining; decrements each billing cycle
  monthsRemaining      Int       @default(12)
  totalCommissionPaid  Float     @default(0)
  /// true while the referred user has an active paid subscription
  isActive             Boolean   @default(false)
  createdAt            DateTime  @default(now())

  affiliate    Affiliate @relation(fields: [affiliateId], references: [id])
  referredUser User      @relation("AffiliateReferredUser", fields: [referredUserId], references: [id])

  @@index([affiliateId])
  @@index([isActive])
}

// ─── Attribution Tracking ─────────────────────────────────────────────────────

model UserAttribution {
  id            String   @id @default(cuid())
  userId        String   @unique

  /// Platform referral code (?ref=)
  ref           String?
  /// Affiliate ID (?affiliate=)
  affiliateId   String?
  /// Acquisition channel: file_delivery | studio_page | artist_page | social | direct | ad
  source        String?
  /// UTM parameters
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  /// First URL the user hit before signing up (populated by client)
  landingPage   String?

  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([source])
  @@index([utmSource])
  @@index([utmCampaign])
}

// ─── Pre-Save Campaigns ───────────────────────────────────────────────────────

model PreSaveCampaign {
  id            String          @id @default(cuid())
  artistId      String
  title         String
  artUrl        String?
  releaseDate   DateTime
  spotifyUrl    String?
  appleMusicUrl String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  artist        User            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  clicks        PreSaveClick[]

  @@index([artistId])
}

// ─── Pre-save click tracking ──────────────────────────────────────────────────

model PreSaveClick {
  id         String          @id @default(cuid())
  campaignId String
  platform   PreSavePlatform
  clickedAt  DateTime        @default(now())

  campaign   PreSaveCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, platform])
}

enum PreSavePlatform {
  SPOTIFY
  APPLE_MUSIC
}

// ─── Artist Videos ────────────────────────────────────────────────────────────

model ArtistVideo {
  id              String         @id @default(cuid())
  artistId        String
  title           String
  description     String?
  videoUrl        String?
  thumbnailUrl    String?
  embedUrl        String?
  type            VideoType      @default(UPLOAD)
  category        VideoCategory?
  duration        Int?
  sortOrder       Int            @default(0)
  isPublished     Boolean        @default(true)
  syncedFromYouTube Boolean       @default(false)
  youtubeVideoId  String?        @unique // YouTube video ID (for deduplication)
  linkedTrackId   String?
  linkedBeatId    String?
  linkedMerchId   String?
  createdAt       DateTime       @default(now())
  artist          User           @relation(fields: [artistId], references: [id], onDelete: Cascade)
  linkedTrack     Track?         @relation("VideoTrackLink", fields: [linkedTrackId], references: [id], onDelete: SetNull)
  linkedBeat      Track?         @relation("VideoBeatLink",  fields: [linkedBeatId],  references: [id], onDelete: SetNull)
  linkedMerch     MerchProduct?  @relation("VideoMerchLink", fields: [linkedMerchId], references: [id], onDelete: SetNull)
}

// ─── YouTube Sync ─────────────────────────────────────────────────────────────

model YouTubeSync {
  id            String     @id @default(cuid())
  userId        String     @unique
  channelId     String
  channelUrl    String
  channelName   String?
  channelAvatar String?
  lastSyncedAt  DateTime?
  nextSyncAt    DateTime?
  syncStatus    SyncStatus @default(PENDING)
  totalVideos   Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Shows & Events ───────────────────────────────────────────────────────────

model ArtistShow {
  id        String         @id @default(cuid())
  artistId  String
  venueName String
  city      String
  date      DateTime
  ticketUrl String?
  isSoldOut Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  artist    User           @relation(fields: [artistId], references: [id], onDelete: Cascade)
  waitlist  ShowWaitlist[]

  @@index([artistId])
}

model ShowWaitlist {
  id        String     @id @default(cuid())
  showId    String
  email     String
  createdAt DateTime   @default(now())

  show      ArtistShow @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([showId, email])
  @@index([showId])
